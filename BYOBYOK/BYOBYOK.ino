void keyTestShow(uint8_t ascii, uint8_t keycode, uint8_t modifier, bool caps) {
  char pr = (ascii >= 32 && ascii < 127) ? (char)ascii : '.';
  char b[72];
  snprintf(b, sizeof(b), "#%-3d key=0x%02X  mods=0x%02X  ascii=0x%02X '%c'  caps=%d",
           ++g_ktCount, keycode, modifier, ascii, pr, caps ? 1 : 0);
  M5.Display.setEpdMode(m5gfx::epd_fast);
  M5.Display.startWrite();
  M5.Display.fillRect(0, 220, W, 44, TFT_WHITE);
  M5.Display.setFont(&fonts::FreeMono12pt7b);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  M5.Display.setTextDatum(m5gfx::top_left);
  M5.Display.drawString(b, MARGIN_X, 228);
  M5.Display.endWrite();
}

// =========================================================================
//  USB drive mode - show the SD card to a computer as a USB stick
// =========================================================================
// The single USB-C port can't be a keyboard host and a USB drive at once, so
// this works as a reboot-into mode: picking "USB drive" sets a one-shot flag
// and restarts; on that boot the keyboard host is skipped and TinyUSB MSC
// serves raw SD sectors instead. Tap / power button / eject restarts back.
bool g_usbDriveMode = false;     // true only on an MSC boot (skips the editor)

#if ENABLE_USB_DRIVE
USBMSC g_msc;
volatile bool g_mscEject = false;

static int32_t mscRead(uint32_t lba, uint32_t offset, void *buffer, uint32_t bufsize) {
  (void)offset;
  for (uint32_t i = 0; i < bufsize / 512; i++)
    if (!SD.readRAW((uint8_t *)buffer + i * 512, lba + i)) return -1;
  return (int32_t)bufsize;
}
static int32_t mscWrite(uint32_t lba, uint32_t offset, uint8_t *buffer, uint32_t bufsize) {
  (void)offset;
  for (uint32_t i = 0; i < bufsize / 512; i++)
    if (!SD.writeRAW(buffer + i * 512, lba + i)) return -1;
  return (int32_t)bufsize;
}
static bool mscStartStop(uint8_t power, bool start, bool eject) {
  (void)power; (void)start;
  if (eject) g_mscEject = true;  // the computer "safely removed" the drive
  return true;
}

void usbDriveFlag(bool on) {
  g_prefs.begin("paper", false);
  g_prefs.putBool("usbdrv", on);
  g_prefs.end();
}
bool usbDriveFlagged() {
  g_prefs.begin("paper", true);
  bool on = g_prefs.getBool("usbdrv", false);
  g_prefs.end();
  return on;
}

// Called from setup() when the one-shot flag is set: no keyboard host, no
// menu - just MSC and a screen. The firmware must not touch the SD
// filesystem while the computer owns it, so loop() short-circuits too.
void usbDriveBoot(bool sdok) {
  g_usbDriveMode = true;
  usbDriveFlag(false);           // one-shot: any restart returns to normal
  M5.Display.setEpdMode(m5gfx::epd_quality);
  M5.Display.startWrite();
  M5.Display.fillScreen(TFT_WHITE);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  M5.Display.setTextDatum(m5gfx::top_left);
  M5.Display.setFont(&fonts::FreeMonoBold18pt7b);
  M5.Display.drawString("USB drive mode", MARGIN_X, 24);
  M5.Display.setFont(&fonts::FreeMono12pt7b);
  int y = 100;
  if (sdok) {
    M5.Display.drawString("Plug the USB-C cable into a computer.", MARGIN_X, y);       y += 38;
    M5.Display.drawString("The SD card appears as a removable drive -", MARGIN_X, y);  y += 38;
    M5.Display.drawString("large cards can take a minute to show up", MARGIN_X, y);    y += 38;
    M5.Display.drawString("(the computer checks the disk first).", MARGIN_X, y);       y += 50;
    M5.Display.drawString("EJECT it on the computer when done: that", MARGIN_X, y);    y += 38;
    M5.Display.drawString("restarts the device and keeps mounts fast.", MARGIN_X, y);  y += 50;
  } else {
    M5.Display.drawString("microSD not found - nothing to share.", MARGIN_X, y);       y += 60;
  }
  M5.Display.drawString("Tap the screen to restart back to writing.", MARGIN_X, y);
  M5.Display.endWrite();
  if (!sdok) return;
  g_msc.vendorID("M5Stack");
  g_msc.productID("BYOBYOK_SD");
  g_msc.productRevision("1.0");
  g_msc.onRead(mscRead);
  g_msc.onWrite(mscWrite);
  g_msc.onStartStop(mscStartStop);
  g_msc.mediaPresent(true);
  bool up = g_msc.begin((uint32_t)(SD.cardSize() / 512), 512);
  if (up) up = USB.begin();

  // Diagnose the two ways this silently fails, right on the screen.
  M5.Display.startWrite();
  M5.Display.setFont(&fonts::FreeMono9pt7b);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  if (!up)
    M5.Display.drawString("USB device stack failed to start - tap to go back.",
                          MARGIN_X, H - 76);
#if defined(ARDUINO_USB_CDC_ON_BOOT) && ARDUINO_USB_CDC_ON_BOOT
  M5.Display.drawString("This build has 'USB CDC On Boot' ENABLED - the drive can NOT appear.",
                        MARGIN_X, H - 52);
  M5.Display.drawString("Set Tools > USB CDC On Boot = Disabled and re-flash.",
                        MARGIN_X, H - 28);
#endif
  M5.Display.endWrite();
}

