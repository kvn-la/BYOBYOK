// Style variants for the Reader's markdown rendering - same mono advance, so
// bold/italic spans never disturb the character grid.
const lgfx::GFXfont *styleFont(bool b, bool i) {
#if USE_LATIN1_FONTS
  switch (g_fontSize) {
    case 0:  return b ? (i ? &DejaVuMono9BI  : &DejaVuMono9B)  : (i ? &DejaVuMono9I  : &DejaVuMono9);
    case 2:  return b ? (i ? &DejaVuMono18BI : &DejaVuMono18B) : (i ? &DejaVuMono18I : &DejaVuMono18);
    default: return b ? (i ? &DejaVuMono12BI : &DejaVuMono12B) : (i ? &DejaVuMono12I : &DejaVuMono12);
  }
#else
  switch (g_fontSize) {
    case 0:  return b ? (i ? &fonts::FreeMonoBoldOblique9pt7b  : &fonts::FreeMonoBold9pt7b)
                      : (i ? &fonts::FreeMonoOblique9pt7b      : &fonts::FreeMono9pt7b);
    case 2:  return b ? (i ? &fonts::FreeMonoBoldOblique18pt7b : &fonts::FreeMonoBold18pt7b)
                      : (i ? &fonts::FreeMonoOblique18pt7b     : &fonts::FreeMono18pt7b);
    default: return b ? (i ? &fonts::FreeMonoBoldOblique12pt7b : &fonts::FreeMonoBold12pt7b)
                      : (i ? &fonts::FreeMonoOblique12pt7b     : &fonts::FreeMono12pt7b);
  }
#endif
}

// LovyanGFX decodes strings as UTF-8; the document buffer stores Latin-1 as
// single bytes (keeping all grid math byte-per-cell), so expand high bytes
// only at the moment text is handed to the display.
String drawable(const String &s) {
#if USE_LATIN1_FONTS
  bool hi = false;
  for (unsigned i = 0; i < s.length(); i++)
    if ((uint8_t)s[i] >= 0x80) { hi = true; break; }
  if (!hi) return s;
  String o;
  o.reserve(s.length() + 8);
  for (unsigned i = 0; i < s.length(); i++) {
    uint8_t c = (uint8_t)s[i];
    if (c < 0x80) o += (char)c;
    else { o += (char)(0xC0 | (c >> 6)); o += (char)(0x80 | (c & 0x3F)); }
  }
  return o;
#else
  return s;
#endif
}

