  M5.Display.setEpdMode(m5gfx::epd_quality);
  M5.Display.startWrite();
  int bw = 680, bh = 210, bx = (W - bw) / 2, by = (H - bh) / 2;
  M5.Display.fillRect(bx, by, bw, bh, TFT_WHITE);
  M5.Display.drawRect(bx, by, bw, bh, TFT_BLACK);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  M5.Display.setTextDatum(m5gfx::top_left);
  M5.Display.setFont(&fonts::FreeMono12pt7b);
  const char *title = (g_promptMode == PM_RENAME)
                        ? "Rename to  (Enter = ok, ESC = cancel):"
                        : (g_promptMode == PM_NEWDIR)
                          ? "New folder name  (Enter = ok, ESC = cancel):"
                          : (g_promptMode == PM_SEARCH)
                            ? "Find  (Enter = next, ESC = back):"
                            : (g_promptMode == PM_GOPAGE)
                              ? "Go to page  (Enter = go, ESC = back):"
                              : "Save as  (Enter = ok, ESC = cancel):";
  M5.Display.drawString(title, bx + 24, by + 26);
  M5.Display.setFont(&fonts::FreeMonoBold18pt7b);
  M5.Display.drawString(g_fname + "_", bx + 24, by + 90);
  M5.Display.setFont(&fonts::FreeMono9pt7b);
  String note;
  if (g_promptMsg.length())           note = g_promptMsg;   // e.g. name collision
  else if (g_promptMode == PM_NEWDIR) note = String("created inside ") + g_cwd;
  else if (g_promptMode == PM_SEARCH) note = g_searchMiss ? "no match found"
                                                          : "case-insensitive; wraps around";
  else if (g_promptMode == PM_GOPAGE)
    note = "1 to " + String(((int)g_lines.size() + g_rows - 1) / g_rows);
  else                                note = "\".txt\" is added automatically if you omit it";
  M5.Display.drawString(note, bx + 24, by + 150);
  M5.Display.endWrite();
}

void enterPrompt(int mode, int after, const String &prefill) {
  g_state = ST_PROMPT;
  g_promptMode = mode;
  g_afterSave = after;
  g_renameTarget = (mode == PM_RENAME) ? prefill : String("");
  g_fname = prefill;
  g_searchMiss = false;
  g_promptMsg = "";
  drawPrompt();
}

// Cancel a prompt, returning to wherever it was opened from. Shared by the
// ESC key and by tapping anywhere (so touch can always back out).
void promptCancel() {
  if (g_promptMode == PM_SAVENEW)      enterEditMenu();  // came from the editor
  else if (g_promptMode == PM_SEARCH ||
           g_promptMode == PM_GOPAGE)  resumeEditor();   // back to the text
  else                                 gotoMenu();       // rename / new-folder
}

void handlePromptKey(uint8_t ascii, uint8_t keycode) {
  if (keycode == KC_ESC) { promptCancel(); return; }
  if (ascii == 8 || keycode == KC_BKSP) {        // backspace
    if (g_fname.length() > 0) g_fname.remove(g_fname.length() - 1);
    g_searchMiss = false;
    g_promptMsg = "";
    drawPrompt();
    return;
  }
  if (ascii == 10 || ascii == 13 || keycode == KC_ENTER) {
    if (g_fname.length() == 0) return;

    if (g_promptMode == PM_SEARCH) {
      g_searchTerm = g_fname;
      int hit = searchDoc(g_searchTerm, cursorPos + 1);
      if (hit >= 0) { cursorPos = hit; desiredCol = -1; resumeEditor(); }
      else          { g_searchMiss = true; drawPrompt(); }
      return;
    }
    if (g_promptMode == PM_GOPAGE) {
      int pages = ((int)g_lines.size() + g_rows - 1) / g_rows;
      int p = g_fname.toInt();
      if (p < 1) p = 1;
      if (p > pages) p = pages;
      int row = (p - 1) * g_rows;
      if (row >= (int)g_lines.size()) row = (int)g_lines.size() - 1;
      cursorPos = g_lines.empty() ? 0 : g_lines[row].start;
      desiredCol = -1;
      resumeEditor();
      return;
    }

    if (g_promptMode == PM_NEWDIR) {
      if (SD.exists(fullPath(g_fname).c_str())) {          // file OR folder
        g_promptMsg = "\"" + g_fname + "\" already exists here - pick another name";
        drawPrompt();
        return;
      }
      SD.mkdir(fullPath(g_fname).c_str());
      cdInto(g_fname);                           // hop into the new folder
      return;
    }

    String low = g_fname; low.toLowerCase();
    String newBase = low.endsWith(".txt") ? g_fname : g_fname + ".txt";

    // Never silently clobber an existing file (FAT is case-insensitive, and
    // the target may even be one the browser hides, like the spell list).
    // Renaming a file to its own name is the harmless no-op exception.
    bool sameName = (g_promptMode == PM_RENAME && newBase == g_renameTarget);
    if (!sameName && SD.exists(fullPath(newBase).c_str())) {
      g_promptMsg = "\"" + newBase + "\" already exists here - pick another name";
      drawPrompt();
      return;
    }

    if (g_promptMode == PM_RENAME) {
      if (!sameName) {
        SD.rename(fullPath(g_renameTarget).c_str(), fullPath(newBase).c_str());
      }
      gotoMenu();
    } else {                                     // PM_SAVENEW
      filename = fullPath(newBase);              // save into the current folder
      saveFile();
      if (g_afterSave == 1) gotoMenu(); else resumeEditor();
    }
    return;
  }
  if (ascii >= 32 && ascii < 127 && ascii != '/' && ascii != '\\') {
    g_fname += (char)ascii;
    g_promptMsg = "";
    drawPrompt();
  }
}

