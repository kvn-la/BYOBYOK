// ---- USB keyboard host ---------------------------------------------------
EspUsbHost usbHost;

// This EspUsbHost runs USB on its own FreeRTOS task and reports keys via a
// callback (not a virtual). The callback fires off the loop() task, so it must
// not draw - it just queues the keypress (KeyEvt + g_keyQueue are defined with
// the BLE decode core above), and loop() processes it on the main task where
// all the e-ink drawing happens (single-threaded display access).

void onKbEvent(const EspUsbHostKeyboardEvent &e) {
  if (!e.pressed) return;                       // key-down events only
  KeyEvt k{ e.ascii, e.keycode, e.modifiers, e.capsLock };
  if (g_keyQueue) xQueueSend(g_keyQueue, &k, 0);
}

void dispatchKey(uint8_t ascii, uint8_t keycode, uint8_t modifier, bool caps) {
  g_lastActivity = millis();                    // any key resets the idle timer

  if (g_state == ST_KEYTEST) {                  // diagnostics: show raw events
    if (keycode == KC_ESC) {
      if (ENABLE_BLE_KEYBOARD) { g_state = ST_BTPAIR; drawBtPair(); }
      else gotoMenu();
    } else keyTestShow(ascii, keycode, modifier, caps);
    return;
  }

  // Ctrl+R on ANY screen: repaint it at full quality (manual de-ghost).
  if ((modifier & (0x11 | 0x88)) && keyLetter(keycode) == 'r' && g_state != ST_KEYTEST) {
    redrawScreen();
    return;
  }

  // Remap printable keys for Dvorak/Colemak; QWERTY keeps the library ascii.
  uint8_t ch = ascii;
  if (g_layout != 0) {
    bool shift = modifier & 0x22;               // left/right shift
    char d = layoutChar(keycode, shift);
    if (d) {
      if (caps && ((d >= 'a' && d <= 'z') || (d >= 'A' && d <= 'Z'))) d ^= 0x20;
      ch = (uint8_t)d;
    }
  }

  switch (g_state) {
    case ST_MENU:     handleMenuKey(ch, keycode); break;
    case ST_EDIT:     handleEditKey(ch, keycode, modifier); break;
    case ST_EDITMENU: handleEditMenuKey(ch, keycode); break;
    case ST_PROMPT:   handlePromptKey(ch, keycode); break;
    case ST_CONFIRM:  handleConfirmKey(ch, keycode); break;
    case ST_EXPORT:   handleExportKey(ch, keycode); break;
    case ST_HELP:     handleHelpKey(ch, keycode); break;
    case ST_READER:   handleReaderKey(ch, keycode); break;
    case ST_BTPAIR:   handleBtPairKey(ch, keycode); break;
    case ST_COUNT:    handleCountKey(ch, keycode); break;
    case ST_GOAL:     handleGoalKey(ch, keycode); break;
    case ST_STATS:    handleStatsKey(ch, keycode); break;
    case ST_SPELL:    handleSpellKey(ch, keycode); break;
    case ST_SYNC:     handleSyncKey(ch, keycode); break;
    case ST_RMENU:    handleReaderMenuKey(ch, keycode); break;
    case ST_GOPAGE:   handleGoPageKey(ch, keycode); break;
  }
}

// =========================================================================
//  Text layout (word-wrap) + caret mapping
// =========================================================================
// ==== TEXTCORE-2 BEGIN ==== (extracted verbatim into tests/ - keep in sync)
void layout() {
  g_lines.clear();
  int n = doc.length();
  // Pre-size the line index in ONE allocation: hard newlines plus a soft-wrap
  // estimate. Without this, growth-by-doubling on a many-line file (e.g. a
  // word list) transiently needs old+new copies at once - an OOM spike.
  {
    int est = 16 + n / (g_cols > 0 ? g_cols : 8);
    for (int k = 0; k < n; k++) if (doc[k] == '\n') est++;
    if ((int)g_lines.capacity() < est) g_lines.reserve(est);
  }
  int lineStart = 0, lastSpace = -1, col = 0, i = 0;
  bool wrappedStart = false;                 // did this line begin from a wrap?
  while (i < n) {
    char c = doc[i];
    if (c == '\n') {
      // A newline right after a wrap shouldn't add a spurious blank line.
      if (!(i == lineStart && wrappedStart)) g_lines.push_back({lineStart, i - lineStart});
      i++; lineStart = i; col = 0; lastSpace = -1; wrappedStart = false;
      continue;
    }
    if (col >= g_cols) {
      if (c == ' ') {                       // absorb a trailing space, then break
        g_lines.push_back({lineStart, i + 1 - lineStart});
        i++; lineStart = i; col = 0; lastSpace = -1; wrappedStart = true;
        continue;
      }
      if (lastSpace >= lineStart) {         // soft break at last space
        int brk = lastSpace + 1;
        g_lines.push_back({lineStart, brk - lineStart});
        lineStart = brk; lastSpace = -1;
        col = i - lineStart;                // keep current i; recount column
        wrappedStart = true;
        continue;
      }
      g_lines.push_back({lineStart, i - lineStart});  // hard break (long word)
      lineStart = i; col = 0; lastSpace = -1; wrappedStart = true;
      continue;
    }
    if (c == ' ') lastSpace = i;
    i++; col++;
  }
  g_lines.push_back({lineStart, n - lineStart});      // final line (may be empty)
}

String lineStr(int idx) {
  const Line &L = g_lines[idx];
  return doc.substring(L.start, L.start + L.len);
}

void caretRowCol(int pos, int &row, int &col) {
  int n = doc.length();
  for (int i = 0; i < (int)g_lines.size(); i++) {
    int s = g_lines[i].start, e = s + g_lines[i].len;
    if (pos < e) { row = i; col = pos - s; return; }
    if (pos == e) {
      bool lastLine   = (i == (int)g_lines.size() - 1);
      bool newlineHere = (e < n) && (doc[e] == '\n');
      if (lastLine || newlineHere) { row = i; col = pos - s; return; }
      // soft-wrap boundary: caret belongs to the start of the next line
    }
  }
  row = (int)g_lines.size() - 1;
  col = g_lines[row].len;
}

int posFromRowCol(int row, int col) {
  if (g_lines.empty()) return 0;
  if (row < 0) row = 0;
  if (row >= (int)g_lines.size()) row = (int)g_lines.size() - 1;
  int c = col;
  if (c < 0) c = 0;
  if (c > g_lines[row].len) c = g_lines[row].len;
  return g_lines[row].start + c;
}

// ---- word count, kept incrementally -------------------------------------
static inline bool wordSpace(char c) { return c == ' ' || c == '\n' || c == '\t' || c == '\r'; }

// Count "word starts" at indices [a,b): a non-space whose predecessor is a
// space (or the start of the document). Summed over the whole doc this equals
// the word count; after an edit only a small window can change.
int countWordStarts(int a, int b) {
  int n = doc.length();
  if (a < 0) a = 0;
  if (b > n) b = n;
  int w = 0;
  for (int i = a; i < b; i++)
    if (!wordSpace(doc[i]) && (i == 0 || wordSpace(doc[i - 1]))) w++;
  return w;
}
int recountWords() { return countWordStarts(0, doc.length()); }

// ---- word-wise caret movement ----------------------------------------------
// One "word" hop: skip separators, then a whole run of non-separators (going
// left), or the mirror image going right - the classic editor behavior.
int wordLeftPos(int pos) {
  if (pos > (int)doc.length()) pos = doc.length();
  while (pos > 0 && wordSpace(doc[pos - 1])) pos--;
  while (pos > 0 && !wordSpace(doc[pos - 1])) pos--;
  return pos;
}
int wordRightPos(int pos) {
  int n = doc.length();
  if (pos < 0) pos = 0;
  while (pos < n && !wordSpace(doc[pos])) pos++;
  while (pos < n && wordSpace(doc[pos])) pos++;
  return pos;
}

// ---- UTF-8 -> ASCII folding -------------------------------------------------
// The built-in FreeMono fonts are 7-bit, so typographic characters in UTF-8
// files (curly quotes, em-dashes, accents...) would render as blank boxes.
// Files are folded to their ASCII equivalents as they load.

// Incremental UTF-8 decoder: feed one byte at a time (sequences may straddle
// read chunks); returns the completed code point, or -1 while mid-sequence
// (invalid bytes are silently dropped).
struct Utf8Fold {
  uint32_t cp = 0;
  int need = 0;
  long feed(uint8_t b) {
    if (b < 0x80) { need = 0; return (long)b; }
    if ((b & 0xC0) == 0x80) {                  // continuation byte
      if (need > 0) {
        cp = (cp << 6) | (b & 0x3F);
        if (--need == 0) return (long)cp;
      }
      return -1;
    }
    if ((b & 0xE0) == 0xC0) { cp = b & 0x1F; need = 1; return -1; }
    if ((b & 0xF0) == 0xE0) { cp = b & 0x0F; need = 2; return -1; }
    if ((b & 0xF8) == 0xF0) { cp = b & 0x07; need = 3; return -1; }
    need = 0;
    return -1;
  }
};

// When Latin-1 capable fonts are compiled in (USE_LATIN1_FONTS), code points
// A0..FF pass through as single Latin-1 bytes instead of being transliterated
// - the grid math stays byte-per-cell, and the fonts have the glyphs.
bool g_keepLatin1 = false;

// ASCII replacement for a non-ASCII code point ("" = drop, "?" = unknown).
const char *asciiFold(uint32_t cp) {
  if (g_keepLatin1 && cp >= 0xA0 && cp <= 0xFF) {
    static char raw[2] = {0, 0};
    raw[0] = (char)cp;
    return raw;
  }
  // Esperanto circumflex/breve letters: internal slots 0x80.. when the fonts
  // carry the glyphs, standard x-notation otherwise.
  static const uint16_t EO_CP[12] = {0x109,0x108,0x11D,0x11C,0x125,0x124,
                                     0x135,0x134,0x15D,0x15C,0x16D,0x16C};
  static const char *EO_X[12] = {"cx","Cx","gx","Gx","hx","Hx",
                                 "jx","Jx","sx","Sx","ux","Ux"};
  for (int k = 0; k < 12; k++) {
    if (cp != EO_CP[k]) continue;
    if (!g_keepLatin1) return EO_X[k];
    static char slot[2] = {0, 0};
    slot[0] = (char)(0x80 + k);
    return slot;
  }
  switch (cp) {
    case 0x2018: case 0x2019: case 0x201A: case 0x201B:
    case 0x2039: case 0x203A: case 0x02BC: return "'";
    case 0x201C: case 0x201D: case 0x201E: case 0x201F:
    case 0x00AB: case 0x00BB: return "\"";
    case 0x2010: case 0x2011: case 0x2013: case 0x2212: return "-";
    case 0x2014: case 0x2015: return "--";
    case 0x2026: return "...";
    case 0x00A0: case 0x2002: case 0x2003: case 0x2007:
    case 0x2009: case 0x200A: case 0x202F: return " ";
    case 0x00AD: case 0x200B: case 0x200C: case 0x200D: case 0xFEFF: return "";
    case 0x2022: case 0x00B7: case 0x25CF: return "*";
    case 0x00A9: return "(c)"; case 0x00AE: return "(R)"; case 0x2122: return "(TM)";
    case 0x00BC: return "1/4"; case 0x00BD: return "1/2"; case 0x00BE: return "3/4";
    case 0x00D7: return "x";   case 0x00F7: return "/";
    case 0x00DF: return "ss";  case 0x00DE: case 0x00FE: return "th";
    case 0x00C6: return "AE";  case 0x00E6: return "ae";
    case 0x0152: return "OE";  case 0x0153: return "oe";
  }
  if (cp >= 0x00C0 && cp <= 0x00FF) {          // Latin-1 letters: drop accents
    static const char *tab =
      "AAAAAA CEEEEIIII"                       // 0xC0..0xCF
      "DNOOOOO OUUUUY  "                       // 0xD0..0xDF
      "aaaaaa ceeeeiiii"                       // 0xE0..0xEF
      "dnooooo ouuuuy y";                      // 0xF0..0xFF
    static char one[2] = {0, 0};
    one[0] = tab[cp - 0x00C0];
    return (one[0] == ' ') ? "?" : one;
  }
  return "?";                                  // visible, unlike a tofu box
}

// ---- incremental re-wrap --------------------------------------------------
// Index of the line whose .start == s (starts are strictly increasing).
static int findLineByStart(int s) {
  int lo = 0, hi = (int)g_lines.size() - 1;
  while (lo <= hi) {
    int mid = (lo + hi) >> 1;
    if (g_lines[mid].start == s) return mid;
    if (g_lines[mid].start < s) lo = mid + 1; else hi = mid - 1;
  }
  return -1;
}

// Re-wrap only what an edit could have changed. The edit replaced delLen
// chars at pos with insLen chars (doc is already updated). The wrap state is
// fully reset by every '\n', so we recompute lines from the start of the
// paragraph containing pos up to the first '\n' past the end of the edit;
// every line before that is untouched and every line after it is the old
// line, shifted by the length delta. Falls back to a full layout() if the
// line list looks inconsistent (defensive - should not happen).
void layoutEdit(int pos, int delLen, int insLen) {
  if (g_lines.empty()) { layout(); return; }
  int n = doc.length(), delta = insLen - delLen, editEnd = pos + insLen;

  int p0 = pos;                                  // paragraph start = a line start
  while (p0 > 0 && doc[p0 - 1] != '\n') p0--;
  int L0 = findLineByStart(p0);
  if (L0 < 0) { layout(); return; }

  // Same wrapping loop as layout(), started fresh at p0.
  std::vector<Line> fresh;
  int lineStart = p0, lastSpace = -1, col = 0, i = p0, tailNew = -1;
  bool wrappedStart = false;
  while (i < n) {
    char c = doc[i];
    if (c == '\n') {
      if (!(i == lineStart && wrappedStart)) fresh.push_back({lineStart, i - lineStart});
      i++; lineStart = i; col = 0; lastSpace = -1; wrappedStart = false;
      if (i > editEnd) { tailNew = i; break; }   // '\n' past the edit: old lines resume
      continue;
    }
    if (col >= g_cols) {
      if (c == ' ') {                            // absorb a trailing space, then break
        fresh.push_back({lineStart, i + 1 - lineStart});
        i++; lineStart = i; col = 0; lastSpace = -1; wrappedStart = true;
        continue;
      }
      if (lastSpace >= lineStart) {              // soft break at last space
        int brk = lastSpace + 1;
        fresh.push_back({lineStart, brk - lineStart});
        lineStart = brk; lastSpace = -1;
        col = i - lineStart;
        wrappedStart = true;
        continue;
      }
      fresh.push_back({lineStart, i - lineStart});  // hard break (long word)
      lineStart = i; col = 0; lastSpace = -1; wrappedStart = true;
      continue;
    }
    if (c == ' ') lastSpace = i;
    i++; col++;
  }

  if (tailNew < 0) {                             // re-wrapped to the very end
    fresh.push_back({lineStart, n - lineStart});
    g_lines.resize(L0);
    g_lines.insert(g_lines.end(), fresh.begin(), fresh.end());
    return;
  }
  int T = findLineByStart(tailNew - delta);      // old line where the tail resumes
  if (T < 0) { layout(); return; }
  std::vector<Line> tail(g_lines.begin() + T, g_lines.end());
  for (auto &L : tail) L.start += delta;
  g_lines.resize(L0);
  g_lines.insert(g_lines.end(), fresh.begin(), fresh.end());
  g_lines.insert(g_lines.end(), tail.begin(), tail.end());
}

// ---- macOS-style character composition ---------------------------------------
// Option + dead key, then a base letter: Option+u,a -> ä. Dead keys follow the
// macOS convention (u diaeresis, e acute, ` grave, i circumflex, n tilde) plus
// b (breve) for Esperanto's ŭ; circumflex composes c/g/h/j/s to ĉĝĥĵŝ (the
// internal 0x80.. slots). Returns the internal byte, 0 if the pair doesn't
// compose. Direct Option characters (å ø ß æ ç) need no second key.
struct ComposeEntry { char dk, base; uint8_t out; };
static const ComposeEntry COMPOSE[] = {
  {'u','a',0xE4},{'u','o',0xF6},{'u','u',0xFC},{'u','e',0xEB},{'u','i',0xEF},{'u','y',0xFF},
  {'u','A',0xC4},{'u','O',0xD6},{'u','U',0xDC},{'u','E',0xCB},{'u','I',0xCF},
  {'e','a',0xE1},{'e','e',0xE9},{'e','i',0xED},{'e','o',0xF3},{'e','u',0xFA},{'e','y',0xFD},
  {'e','A',0xC1},{'e','E',0xC9},{'e','I',0xCD},{'e','O',0xD3},{'e','U',0xDA},{'e','Y',0xDD},
  {'`','a',0xE0},{'`','e',0xE8},{'`','i',0xEC},{'`','o',0xF2},{'`','u',0xF9},
  {'`','A',0xC0},{'`','E',0xC8},{'`','I',0xCC},{'`','O',0xD2},{'`','U',0xD9},
  {'i','a',0xE2},{'i','e',0xEA},{'i','i',0xEE},{'i','o',0xF4},{'i','u',0xFB},
  {'i','A',0xC2},{'i','E',0xCA},{'i','I',0xCE},{'i','O',0xD4},{'i','U',0xDB},
  {'i','c',0x80},{'i','C',0x81},{'i','g',0x82},{'i','G',0x83},{'i','h',0x84},
  {'i','H',0x85},{'i','j',0x86},{'i','J',0x87},{'i','s',0x88},{'i','S',0x89},
  {'n','n',0xF1},{'n','N',0xD1},{'n','a',0xE3},{'n','A',0xC3},{'n','o',0xF5},{'n','O',0xD5},
  {'b','u',0x8A},{'b','U',0x8B},
};
uint8_t composeChar(char dk, char base) {
  for (auto &e : COMPOSE) if (e.dk == dk && e.base == base) return e.out;
  return 0;
}
uint8_t optionChar(char key) {
  switch (key) {
    case 'a': return 0xE5; case 'A': return 0xC5;   // å Å
    case 'o': return 0xF8; case 'O': return 0xD8;   // ø Ø
    case 'c': return 0xE7; case 'C': return 0xC7;   // ç Ç
    case 's': return 0xDF;                          // ß
    case '\'': return 0xE6; case '"': return 0xC6;  // æ Æ
  }
  return 0;
}
bool composeDead(char k) {
  return k == 'u' || k == 'e' || k == 'i' || k == 'n' || k == 'b' || k == '`';
}

// ---- markdown emphasis (rendered by the Reader) -----------------------------
// **text** toggles bold, *text* toggles italic (a "* " bullet at the very
// start of a paragraph stays literal), and a paragraph starting with '#' is a
// heading (whole line bold). Emphasis resets at every hard newline. Markers
// stay visible - only the text between them changes style - so the character
// grid and wrap math are untouched.
// Computes the style state at `pos` by scanning from its paragraph start;
// parStart is returned for the renderer's bullet check. (A ** split across a
// soft wrap may momentarily mis-style one line - cosmetic, self-corrects.)
void mdStateAt(int pos, int &parStart, bool &bold, bool &ital, bool &heading) {
  int p0 = pos;
  while (p0 > 0 && doc[p0 - 1] != '\n') p0--;
  parStart = p0;
  bold = ital = false;
  heading = (p0 < (int)doc.length() && doc[p0] == '#');
  int i = p0;
  while (i < pos) {
    if (doc[i] != '*') { i++; continue; }
    if (i + 1 < pos && doc[i + 1] == '*') { bold = !bold; i += 2; continue; }
    bool bullet = (i == p0 && i + 1 < (int)doc.length() &&
                   (doc[i + 1] == ' ' || doc[i + 1] == '\t'));
    if (!bullet) ital = !ital;
    i++;
  }
}

// ---- search ---------------------------------------------------------------
// Case-insensitive find, starting at `from`, wrapping around the document.
// Returns the match index or -1.
int searchDoc(const String &needle, int from) {
  int n = doc.length(), m = (int)needle.length();
  if (m == 0 || m > n) return -1;
  if (from < 0 || from >= n) from = 0;
  auto low = [](char c) { return (c >= 'A' && c <= 'Z') ? (char)(c + 32) : c; };
  for (int k = 0; k < n; k++) {
    int i = (from + k) % n;
    if (i + m > n) continue;
    bool hit = true;
    for (int j = 0; j < m; j++)
      if (low(doc[i + j]) != low(needle[j])) { hit = false; break; }
    if (hit) return i;
  }
  return -1;
}

// ---- undo journal -----------------------------------------------------------
// Every edit goes through docReplace, so undo is a journal of inverses:
// "insLen chars were inserted at pos, replacing del". Runs of single-char
// typing / backspacing coalesce into one entry so Ctrl+Z steps feel chunky.
struct UndoOp { int pos; int insLen; String del; };
std::vector<UndoOp> g_undo;
bool g_undoSuppress = false;         // true while undoLast applies an inverse
const int UNDO_MAX = 200;            // entries kept (typing coalesces, so ~generous)

void undoClear() { g_undo.clear(); }

void recordUndo(int pos, const String &del, int insLen) {
  if (g_undoSuppress) return;
  int delLen = (int)del.length();
  if (!g_undo.empty()) {
    UndoOp &last = g_undo.back();
    // coalesce a run of typing: single insert right after the previous one
    if (delLen == 0 && insLen == 1 && (int)last.del.length() == 0 &&
        last.insLen > 0 && last.insLen < 32 && pos == last.pos + last.insLen) {
      last.insLen++;
      return;
    }
    // coalesce a run of backspacing: single deletes walking left
    if (insLen == 0 && delLen == 1 && last.insLen == 0 &&
        (int)last.del.length() > 0 && (int)last.del.length() < 32 &&
        pos == last.pos - 1) {
      String t; t += del[0]; t += last.del;
      last.del = t;
      last.pos = pos;
      return;
    }
  }
  UndoOp op; op.pos = pos; op.insLen = insLen; op.del = del;
  g_undo.push_back(op);
  if ((int)g_undo.size() > UNDO_MAX) g_undo.erase(g_undo.begin());
}

// Single entry point for all edits: replaces delLen chars at pos with the
// insLen bytes at s, updates the word count by re-examining only the window
// whose word-boundary status could have changed, re-wraps incrementally, and
// records the inverse in the undo journal.
// Returns how many chars were actually inserted (0 if out of memory).
int docReplace(int pos, int delLen, const char *s, int insLen) {
  int n = doc.length();
  if (pos < 0) pos = 0;
  if (pos > n) pos = n;
  if (delLen < 0) delLen = 0;
  if (delLen > n - pos) delLen = n - pos;
  String deleted;
  if (delLen > 0 && !g_undoSuppress) deleted = doc.substring(pos, pos + delLen);
  g_docWords -= countWordStarts(pos, pos + delLen + 1);
  doc.erase(pos, delLen);
  if (insLen > 0 && !doc.insert(pos, s, insLen)) insLen = 0;
  g_docWords += countWordStarts(pos, pos + insLen + 1);
  layoutEdit(pos, delLen, insLen);
  recordUndo(pos, deleted, insLen);
  return insLen;
}

// Revert the newest undo entry. Returns the caret position to move to after
// the revert, or -1 if there was nothing to undo.
int undoLast() {
  if (g_undo.empty()) return -1;
  UndoOp op = g_undo.back();
  g_undo.pop_back();
  g_undoSuppress = true;
  docReplace(op.pos, op.insLen, op.del.c_str(), (int)op.del.length());
  g_undoSuppress = false;
  return op.pos + (int)op.del.length();
}
// ==== TEXTCORE-2 END ====

// ==== SPELLCORE BEGIN ==== (extracted verbatim into tests/ - keep in sync)
// Spell check against a plain word list, one word per line - any standard
// dictionary file works as-is (mixed case, possessives, accents, any sort
// order: the list is normalized at load). Held in memory, binary-searched
// over line offsets.
char *g_dict = nullptr;
int   g_dictLen = 0;
std::vector<int> g_dictOff;              // offset of each line in g_dict

void dictIndex() {
  g_dictOff.clear();
  bool atStart = true;
  for (int i = 0; i < g_dictLen; i++) {
    char c = g_dict[i];
    if (atStart && c != '\n' && c != '\r') { g_dictOff.push_back(i); atStart = false; }
    if (c == '\n') atStart = true;
  }
}

// Normalize the indexed list so binary search works no matter how the file
// was formatted: lowercase everything in place, then sort the line offsets
// into byte order. Standard lists (macOS/Linux words, SCOWL) mix cases and
// collations, and lowercasing changes the byte order anyway - documents are
// compared as lowercase ASCII, so the list must be too. One-time cost at load.
void dictNormalize() {
  for (int i = 0; i < g_dictLen; i++) {
    char c = g_dict[i];
    if (c >= 'A' && c <= 'Z') g_dict[i] = (char)(c + 32);
  }
  std::sort(g_dictOff.begin(), g_dictOff.end(), [](int a, int b) {
    for (int j = 0; ; j++) {
      char ca = (a + j < g_dictLen) ? g_dict[a + j] : '\n';
      char cb = (b + j < g_dictLen) ? g_dict[b + j] : '\n';
      if (ca == '\r' || ca == '\n') ca = 0;
      if (cb == '\r' || cb == '\n') cb = 0;
      if (ca != cb) return (unsigned char)ca < (unsigned char)cb;
      if (ca == 0) return false;
    }
  });
}

// compare a lowercase word of length wl against the dictionary line at off
static int dictCmp(const char *w, int wl, int off) {
  for (int j = 0; ; j++) {
    char d = (off + j < g_dictLen) ? g_dict[off + j] : '\n';
    if (d == '\r' || d == '\n') d = 0;
    char c = (j < wl) ? w[j] : 0;
    if (c != d) return ((unsigned char)c < (unsigned char)d) ? -1 : 1;
    if (c == 0) return 0;
  }
}

// Words learned at runtime ('l' on the spell screen). The sketch also appends
// them to the list file, so they're in the sorted index from the next boot.
std::vector<String> g_dictLearned;
void dictLearn(const char *w) { g_dictLearned.push_back(String(w)); }

bool dictHas(const char *w, int wl) {
  int lo = 0, hi = (int)g_dictOff.size() - 1;
  while (lo <= hi) {
    int mid = (lo + hi) >> 1;
    int c = dictCmp(w, wl, g_dictOff[mid]);
    if (c == 0) return true;
    if (c < 0) hi = mid - 1; else lo = mid + 1;
  }
  for (auto &lw : g_dictLearned)               // small linear overlay
    if ((int)lw.length() == wl && memcmp(lw.c_str(), w, wl) == 0) return true;
  return false;
}

static inline bool wordLetter(char c) { return (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z'); }

// Next word in the doc at/after `from`: fills out[] lowercased (truncated to
// maxLen-1), returns the index just past the word, or -1 at end of document.
// Apostrophes inside a word (don't, dog's) are part of it.
int docNextWord(int from, char *out, int maxLen, int &wl) {
  int n = doc.length(), i = from;
  while (i < n && !wordLetter(doc[i])) i++;
  if (i >= n) return -1;
  wl = 0;
  while (i < n) {
    char c = doc[i];
    bool apos = (c == '\'' && wl > 0 && i + 1 < n && wordLetter(doc[i + 1]));
    if (!wordLetter(c) && !apos) break;
    if (wl < maxLen - 1) {
      if (c >= 'A' && c <= 'Z') c += 32;
      out[wl++] = c;
    }
    i++;
  }
  out[wl] = 0;
  return i;
}

// Scan the whole document; collect up to maxOut unique words that are missing
// from the dictionary, with occurrence counts. Single letters are skipped and
// possessives fall back to the base word. Returns the number collected, or -1
// if no dictionary is loaded.
int spellScan(String *words, int *counts, int maxOut) {
  if (!g_dict || g_dictOff.empty()) return -1;
  char w[32];
  int wl = 0, found = 0, pos = 0;
  while ((pos = docNextWord(pos, w, (int)sizeof(w), wl)) >= 0) {
    if (wl < 2) continue;
    bool ok = dictHas(w, wl);
    if (!ok && wl > 2 && w[wl - 2] == '\'' && w[wl - 1] == 's')
      ok = dictHas(w, wl - 2);                 // dog's -> dog
    if (ok) continue;
    int k = 0;
    for (; k < found; k++) if (words[k] == w) { counts[k]++; break; }
    if (k < found) continue;
    if (found < maxOut) { words[found] = w; counts[found] = 1; found++; }
  }
  return found;
}
// ==== SPELLCORE END ====

// =========================================================================
//  Paths & SD helpers (folder-aware)
// =========================================================================
// g_cwd always ends in '/'. fullPath("todo.txt") -> "/notes/todo.txt".
String fullPath(const String &base) { return g_cwd + base; }
String baseName(const String &path) {
  int s = path.lastIndexOf('/');
  return (s >= 0) ? path.substring(s + 1) : path;
}
// Path to hand SD.open for the current directory (no trailing '/' except root).
String dirOpenPath() {
  if (g_cwd == "/") return "/";
  String p = g_cwd;
  if (p.endsWith("/")) p.remove(p.length() - 1);
  return p;
}

// Rebuild the menu entry list for the current directory.
void buildEntries() {
  g_entries.clear();
  if (g_moveSrc.length()) {                    // move mode: drop / cancel on top
    g_entries.push_back({E_MOVEHERE, ""});
    g_entries.push_back({E_MOVECANCEL, ""});
  } else {
    if (g_cwd == "/" && g_lastFile.length() && SD.exists(g_lastFile.c_str()))
      g_entries.push_back({E_CONTINUE, ""});   // resume where you left off
    if (g_kbConnected) {                       // creating files needs keys to
      g_entries.push_back({E_NEWFILE, ""});    // type a name - don't show what
      g_entries.push_back({E_NEWDIR,  ""});    // can't be used
    }
  }
  if (g_cwd != "/") g_entries.push_back({E_UP, ""});

  std::vector<String> dirs, files;
  File root = SD.open(dirOpenPath().c_str());
  if (root) {
    for (File f = root.openNextFile(); f; f = root.openNextFile()) {
      String nm = baseName(String(f.name()));
      // Hide OS litter: dot-entries cover macOS's .DS_Store / ._AppleDouble /
      // .Spotlight-V100 / .Trashes etc. (and our own dot-files).
      if (nm.length() == 0 || nm[0] == '.') continue;
      if (f.isDirectory()) {
        if (nm == "System Volume Information") continue;   // Windows litter
        dirs.push_back(nm);
      } else {
        String low = nm; low.toLowerCase();
        if (g_cwd == "/" && ("/" + low) == DICT_PATH) continue;  // spell dict
        if (low.endsWith(".txt")) files.push_back(nm);
      }
    }
    root.close();
  }
  for (auto &d : dirs)  g_entries.push_back({E_DIR,  d});
  for (auto &f : files) g_entries.push_back({E_FILE, f});
}

// Write a run of buffer text as valid UTF-8: the buffer stores Latin-1 as
// single bytes (grid math), but files on disk must stay UTF-8, or the next
// load's decoder would drop the accented characters as malformed sequences.
static void writeUtf8Run(File &f, const char *p, int n) {
  uint8_t out[512];
  int m = 0;
  for (int i = 0; i < n; i++) {
    uint8_t c = (uint8_t)p[i];
    if (m >= (int)sizeof(out) - 2) { f.write(out, m); m = 0; }
    if (c < 0x80) { out[m++] = c; continue; }
    uint16_t cp = c;
    if (c >= 0x80 && c < 0x8C) {               // Esperanto slots -> real code points
      static const uint16_t eo[12] = {0x109,0x108,0x11D,0x11C,0x125,0x124,
                                      0x135,0x134,0x15D,0x15C,0x16D,0x16C};
      cp = eo[c - 0x80];
    }
    out[m++] = 0xC0 | (cp >> 6);
    out[m++] = 0x80 | (cp & 0x3F);
  }
  if (m) f.write(out, m);
}

bool saveFile() {
  if (filename.length() == 0) return false;
  File f = SD.open(filename.c_str(), FILE_WRITE, true);   // filename is a full path
  if (!f) return false;
  // The gap buffer is two contiguous runs of text - stream both out.
  if (doc.part1Len() > 0) writeUtf8Run(f, doc.part1(), doc.part1Len());
  if (doc.part2Len() > 0) writeUtf8Run(f, doc.part2(), doc.part2Len());
  f.close();
  modified = false;
  return true;
}

void loadDoc(const String &path) {
  filename = path;                                        // store the full path
  doc.clear();
  File f = SD.open(path.c_str(), FILE_READ);
  if (f) {
    doc.reserve((int)f.size() + 4096);
    // Strip CRs and fold UTF-8 typography to ASCII (see asciiFold). keep[] is
    // oversized because folding can expand (em-dash -> "--", etc.).
    char buf[512], keep[1024];
    Utf8Fold u8;
    while (f.available()) {
      int n = f.readBytes(buf, 512), m = 0;
      for (int i = 0; i < n; i++) {
        long cp = u8.feed((uint8_t)buf[i]);
        if (cp < 0 || cp == '\r') continue;              // pending / CRLF -> LF
        if (cp < 0x80) { keep[m++] = (char)cp; continue; }
        for (const char *r = asciiFold((uint32_t)cp); *r; r++) keep[m++] = *r;
      }
      doc.insert(doc.length(), keep, m);
      yield();                                           // feed the watchdog
    }
    f.close();
  }
  g_docWords = recountWords();
  undoClear();
  g_sessStartWords = g_docWords;               // baseline for the stats log
  cursorPos = 0; desiredCol = -1; modified = false; topLine = 0;
}

// Stream-copy src -> dst (rolling .bak backup taken when a file is opened).
bool copyFile(const String &src, const String &dst) {
  File in = SD.open(src.c_str(), FILE_READ);
  if (!in) return false;
  File out = SD.open(dst.c_str(), FILE_WRITE, true);
  if (!out) { in.close(); return false; }
  uint8_t buf[512];
  while (in.available()) {
    int n = in.read(buf, sizeof(buf));
    if (n <= 0) break;
    out.write(buf, n);
    yield();                                   // large backups: feed the watchdog
  }
  out.close(); in.close();
  return true;
}

// ---- resume-where-you-left-off (persisted in NVS) -------------------------
void loadResume() {
  g_prefs.begin("paper", true);
  g_lastFile = g_prefs.getString("lastfile", "");
  g_lastPos  = g_prefs.getInt("lastpos", 0);
  g_prefs.end();
}
void saveResume() {
  if (filename.length() == 0) return;          // unnamed buffers can't resume
  g_lastFile = filename; g_lastPos = cursorPos;
  g_prefs.begin("paper", false);
  g_prefs.putString("lastfile", g_lastFile);
  g_prefs.putInt("lastpos", g_lastPos);
  g_prefs.end();
}

// ---- session stats: append "YYYY-MM-DD,words" to /.ptstats.csv ------------
// (dot-file: invisible to the .txt-only menu and WiFi export listings)
void sessionEnd() {
  int delta = g_docWords - g_sessStartWords;
  g_sessStartWords = g_docWords;               // never double-log a session
  if (delta <= 0 || !g_rtcOk) return;
  auto dt = M5.Rtc.getDateTime();
  char line[40];
  snprintf(line, sizeof(line), "%04d-%02d-%02d,%d\n",
           (int)dt.date.year, (int)dt.date.month, (int)dt.date.date, delta);
  File f = SD.open("/.ptstats.csv", FILE_APPEND);
  if (f) { f.print(line); f.close(); }
}

// Can a file of this size be opened comfortably? The text costs ~1.5x its
// size in the gap buffer plus the line index and transients. Refusing here
// beats a hard out-of-memory abort (exceptions are off on this platform).
bool docFits(const String &path, uint32_t &szOut) {
  File f = SD.open(path.c_str(), FILE_READ);
  szOut = f ? (uint32_t)f.size() : 0;
  if (f) f.close();
  uint32_t need = szOut * 2 + szOut / 2 + 262144;
  uint32_t have = heap_caps_get_free_size(MALLOC_CAP_SPIRAM);
  if (have < 65536)                              // no PSRAM: internal only
    have = heap_caps_get_free_size(MALLOC_CAP_8BIT) / 2;
  return need < have;
}

// Full-screen message that any key or tap dismisses (borrows the help state).
void msgScreen(const String &l1, const String &l2) {
  applyRotation(false);
  M5.Display.setEpdMode(m5gfx::epd_quality);
  M5.Display.startWrite();
  M5.Display.fillScreen(TFT_WHITE);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  M5.Display.setTextDatum(m5gfx::top_left);
  M5.Display.setFont(&fonts::FreeMonoBold18pt7b);
  M5.Display.drawString("Hmm.", MARGIN_X, 24);
  M5.Display.setFont(&fonts::FreeMono12pt7b);
  M5.Display.drawString(l1, MARGIN_X, 110);
  M5.Display.drawString(l2, MARGIN_X, 150);
  M5.Display.setFont(&fonts::FreeMono9pt7b);
  M5.Display.drawString("Press any key or tap to go back.", MARGIN_X, H - 28);
  M5.Display.endWrite();
  g_state = ST_HELP;                             // any key / tap -> menu
}

// Open a file (full path) for editing: snapshot a .bak of it first (cheap
// insurance against a bad session - restore by renaming), and put the caret
// back where it was if this is the file we last worked on.
void openForEditing(const String &path) {
  uint32_t sz;
  if (!docFits(path, sz)) {
    msgScreen("\"" + baseName(path) + "\" is too large to open here",
              "(" + String(sz / 1024) + " KB - not enough free memory).");
    return;
  }
  copyFile(path, path + ".bak");
  loadDoc(path);
  if (path == g_lastFile && g_lastPos > 0 && g_lastPos <= (int)doc.length())
    cursorPos = g_lastPos;
  enterEditor();
}

void openFile(const String &name)       { openForEditing(fullPath(name)); }            // edit
void openForReading(const String &name) { readerOpen(fullPath(name), 0); }             // read

// 'j' in the menu: today's journal, /journal/YYYY-MM-DD.txt, caret at the end.
void openJournal() {
  if (!g_kbConnected) return;                  // writing needs a keyboard
  SD.mkdir("/journal");
  String path = "/journal/journal.txt";        // fallback if the RTC is dead
  if (g_rtcOk) {
    auto dt = M5.Rtc.getDateTime();
    char b[36];
    snprintf(b, sizeof(b), "/journal/%04d-%02d-%02d.txt",
             (int)dt.date.year, (int)dt.date.month, (int)dt.date.date);
    path = b;
  }
  copyFile(path, path + ".bak");               // no-op if it doesn't exist yet
  loadDoc(path);                               // empty buffer if it's new
  filename = path;                             // first save creates it
  cursorPos = doc.length();                    // append to the day
  enterEditor();
}

// Empty the buffer and everything tied to its contents (word count, undo).
// GapBuffer::clear also frees the PSRAM allocation.
void clearDoc() {
  doc.clear();
  g_docWords = 0;
  g_sessStartWords = 0;
  undoClear();
}

void newFile() {
  clearDoc();
  filename = ""; cursorPos = 0; desiredCol = -1; modified = false; topLine = 0;
  enterEditor();
}

void cdInto(const String &name) { g_cwd += name + "/"; g_sel = 0; menuTop = 0; buildEntries(); drawMenu(); }
void cdUp() {
  if (g_cwd == "/") return;
  String p = g_cwd;
  if (p.endsWith("/")) p.remove(p.length() - 1);
  int s = p.lastIndexOf('/');
  g_cwd = (s <= 0) ? String("/") : p.substring(0, s + 1);
  g_sel = 0; menuTop = 0; buildEntries(); drawMenu();
}

// Finish a move: rename the source into the folder being browsed. The .bak
// sidecar and the [ Continue ] pointer follow the file.
void moveDrop() {
  String dst = fullPath(baseName(g_moveSrc));
  if (dst == g_moveSrc) { gotoMenu(); return; }          // same folder: done
  if (SD.exists(dst.c_str())) {
    g_moveMsg = "A file with that name is already here - pick another folder. ESC = cancel";
    drawMenu();
    return;
  }
  if (!SD.rename(g_moveSrc.c_str(), dst.c_str())) {
    g_moveMsg = "Move failed - pick another folder. ESC = cancel";
    drawMenu();
    return;
  }
  if (SD.exists((g_moveSrc + ".bak").c_str()))
    SD.rename((g_moveSrc + ".bak").c_str(), (dst + ".bak").c_str());
  if (g_lastFile == g_moveSrc) {                         // [ Continue ] follows
    g_lastFile = dst;
    g_prefs.begin("paper", false);
    g_prefs.putString("lastfile", g_lastFile);
    g_prefs.end();
  }
  gotoMenu();                                            // clears the move state
}

// =========================================================================
//  Editor rendering
// =========================================================================
void readBattery() {
  // No fuel-gauge chip on this board: the percentage is derived from battery
  // VOLTAGE, so it reads ~20-30 points high while charging and sags under
  // load. Average a few samples to stop the number fluttering; the charging
  // inflation itself can't be fixed in firmware (the UI marks it with '~').
  long sum = 0; int n = 0;
  for (int i = 0; i < 4; i++) {
    int p = M5.Power.getBatteryLevel();       // 0..100, or <0 if unknown
    if (p >= 0) { sum += p; n++; }
  }
  int p = n ? (int)(sum / n) : -1;
  if (p > 100) p = 100;
  g_batPct = p;
  g_charging = (M5.Power.isCharging() == 1);
}

// Seed the BM8563 RTC from the build time the first time only (year unset).
// Afterward the battery-backed RTC keeps ticking on its own across resets.
void setupRtc() {
  g_rtcOk = M5.Rtc.isEnabled();
  if (!g_rtcOk) return;
  auto dt = M5.Rtc.getDateTime();
  if (dt.date.year < 2025) {
    static const char *mons = "JanFebMarAprMayJunJulAugSepOctNovDec";
    char ms[4] = {0};
    int d = 1, y = 2025, hh = 0, mm = 0, ss = 0;
    sscanf(__DATE__, "%3s %d %d", ms, &d, &y);
    sscanf(__TIME__, "%d:%d:%d", &hh, &mm, &ss);
    const char *p = strstr(mons, ms);
    int mon = p ? (int)((p - mons) / 3) + 1 : 1;
    m5::rtc_datetime_t set;
    set.date.year = y; set.date.month = mon; set.date.date = d; set.date.weekDay = 0;
    set.time.hours = hh; set.time.minutes = mm; set.time.seconds = ss;
    M5.Rtc.setDateTime(set);
  }
}

String clockStr() {
  auto dt = M5.Rtc.getDateTime();
  char buf[6];
  snprintf(buf, sizeof(buf), "%02d:%02d", (int)dt.time.hours, (int)dt.time.minutes);
  return String(buf);
}

// The live count is maintained incrementally by docReplace(); loads recount
// once via recountWords(). No full-document scan per keystroke.
int countWords() { return g_docWords; }

// Draws a battery glyph whose right edge (incl. terminal nub) sits at rightX.
void drawBattery(int rightX, int y) {
  const int w = 26, h = 13, nub = 3;
  int x = rightX - w - nub;
  M5.Display.drawRect(x, y, w, h, TFT_BLACK);
  M5.Display.fillRect(x + w, y + 4, nub, h - 8, TFT_BLACK);   // + terminal
  if (g_batPct >= 0) {
    int innerW = w - 4;
    int fw = innerW * g_batPct / 100;
    if (fw < 0) fw = 0;
    if (fw > innerW) fw = innerW;
    M5.Display.fillRect(x + 2, y + 2, fw, h - 4, TFT_BLACK);
  }
}

// Battery icon + percentage, right edge at rightX. Reads the gauge itself and
// returns the x coordinate just left of the cluster (for right-aligned text).
// Shared by the status bar and the main menu header.
int drawBatteryCluster(int rightX, int iconY, int textY) {
  readBattery();
  drawBattery(rightX, iconY);
  String pctS = (g_batPct >= 0 ? String(g_batPct) : String("--")) + "%";
  if (g_charging) pctS = "~" + pctS + "+";    // '~': voltage reads high on charge
  M5.Display.setFont(&fonts::FreeMono9pt7b);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  M5.Display.setTextDatum(m5gfx::top_right);
  int pctRight = rightX - 26 - 3 - 8;              // just left of the icon
  M5.Display.drawString(pctS, pctRight, textY);
  M5.Display.setTextDatum(m5gfx::top_left);
  return pctRight - M5.Display.textWidth(pctS);
}

// Standard modal dialog frame: white fill, double border, bold title.
// Returns the top-left corner via bx/by; callers add their content below.
void modalFrame(int bw, int bh, const char *title, int &bx, int &by) {
  bx = (W - bw) / 2; by = (H - bh) / 2;
  M5.Display.fillRect(bx, by, bw, bh, TFT_WHITE);
  M5.Display.drawRect(bx, by, bw, bh, TFT_BLACK);
  M5.Display.drawRect(bx + 1, by + 1, bw - 2, bh - 2, TFT_BLACK);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  M5.Display.setTextDatum(m5gfx::top_left);
  M5.Display.setFont(&fonts::FreeMonoBold18pt7b);
  M5.Display.drawString(title, bx + 30, by + 22);
}

// A modal selection list (frame + highlighted rows). Geometry is recorded so
// tap handlers can map a touch back to a row - every dialog stays operable by
// touch alone, in case the only keyboard just went to sleep.
int g_mlX = 0, g_mlY = 0, g_mlW = 0, g_mlH = 0;       // frame
int g_mlListY = 0, g_mlItemH = 0, g_mlCount = 0;      // rows
String (*g_mlLabelFn)(int) = nullptr;                 // for selection moves

void drawModalRow(int i, bool sel) {
  int y = g_mlListY + i * g_mlItemH;
  M5.Display.setFont(&fonts::FreeMono12pt7b);
  M5.Display.setTextDatum(m5gfx::top_left);
  M5.Display.fillRect(g_mlX + 16, y - 4, g_mlW - 32, g_mlItemH,
                      sel ? TFT_BLACK : TFT_WHITE);
  M5.Display.setTextColor(sel ? TFT_WHITE : TFT_BLACK, sel ? TFT_BLACK : TFT_WHITE);
  M5.Display.drawString(g_mlLabelFn(i), g_mlX + 30, y);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
}

// Arrow moves inside a modal list: repaint just the two rows, no flash.
void modalListMoveSel(int from, int to) {
  if (!g_mlLabelFn || from == to || to < 0 || to >= g_mlCount) return;
  M5.Display.setEpdMode(m5gfx::epd_fast);
  M5.Display.startWrite();
  drawModalRow(from, false);
  drawModalRow(to, true);
  M5.Display.endWrite();
}

void drawModalList(const char *title, int bw, int bh, String (*label)(int), int count, int sel) {
  M5.Display.setEpdMode(m5gfx::epd_quality);
  M5.Display.startWrite();
  int bx, by;
  modalFrame(bw, bh, title, bx, by);
  M5.Display.setFont(&fonts::FreeMono12pt7b);
  g_mlX = bx; g_mlY = by; g_mlW = bw; g_mlH = bh;
  g_mlListY = by + 84;
  g_mlItemH = M5.Display.fontHeight() + 16;
  g_mlCount = count;
  g_mlLabelFn = label;
  for (int i = 0; i < count; i++) drawModalRow(i, i == sel);
  M5.Display.endWrite();
}

// Map a tap to a list row: -1 = outside the dialog, -2 = inside but no row.
int modalListHit(int x, int y) {
  if (x < g_mlX || x > g_mlX + g_mlW || y < g_mlY || y > g_mlY + g_mlH) return -1;
  int r = (y - (g_mlListY - 4)) / g_mlItemH;
  if (y < g_mlListY - 4 || r < 0 || r >= g_mlCount) return -2;
  return r;
}

void drawStatusBar() {
  M5.Display.fillRect(0, 0, W, statusH, TFT_WHITE);
  M5.Display.drawFastHLine(0, statusH - 1, W, TFT_BLACK);
  M5.Display.setFont(&fonts::FreeMono9pt7b);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  int ty = 5;
  int iconY = (statusH - 13) / 2; if (iconY < 0) iconY = 0;

  // left: filename + unsaved marker (+ goal progress + focus flag)
  M5.Display.setTextDatum(m5gfx::top_left);
  String left = (filename.length() ? baseName(filename) : String("[new]"));
  if (modified) left += " *";
  if (g_goalMode == 1) {                       // sprint: minutes remaining
    long rem = (long)g_goalTarget * 60000L - (long)(millis() - g_goalStartMs);
    if (rem < 0) rem = 0;
    left += " [" + String((int)((rem + 59999L) / 60000L)) + "m left]";
  } else if (g_goalMode == 2) {                // word goal: progress
    int got = g_docWords - g_goalStartWords;
    if (got < 0) got = 0;
    left += " [" + String(got) + "/" + String(g_goalTarget) + "w]";
  }
  if (g_focus) left += " [focus]";
  M5.Display.drawString(left, MARGIN_X, ty);

  // right cluster (right-aligned):  hints ... pct% ... [icon]
  // No live word/char count here: keeping it off the bar means the bar only
  // redraws when the "*" flips or on the 20 s tick, so a keystroke's e-ink
  // refresh stays confined to the line being typed. Ctrl+W shows the counts.
  int hintsRight = drawBatteryCluster(W - MARGIN_X, iconY, ty) - 14;
  String hints;
  if (g_rtcOk) hints = clockStr() + "   ";
  int pgT = ((int)g_lines.size() + g_rows - 1) / g_rows;
  if (pgT < 1) pgT = 1;
  hints += "p." + String(g_caretRow / g_rows + 1) + "/" + String(pgT) +
           "   Ctrl+W count   ESC menu";
  M5.Display.setTextDatum(m5gfx::top_right);
  M5.Display.drawString(hints, hintsRight, ty);
  M5.Display.setTextDatum(m5gfx::top_left);
}

void refreshStatusBar() {
  M5.Display.setEpdMode(m5gfx::epd_fast);
  M5.Display.startWrite();
  drawStatusBar();
  M5.Display.endWrite();
}

void drawCaret(int screenRow, int col) {
  int x = textX + col * charW;
  int y = textY + screenRow * lineH;
  M5.Display.fillRect(x, y, 2, lineH - 4, TFT_BLACK);
}

// Composition feedback: while a dead key is pending, the caret cell shows the
// accent inverted (like macOS's highlighted accent). Called again after the
// pending state clears to restore a plain caret.
void drawPendingAccent() {
  int r = g_caretRow - topLine;
  if (r < 0 || r >= g_rows) return;
  int x = textX + g_caretCol * charW, y = textY + r * lineH;
  M5.Display.setEpdMode(m5gfx::epd_fast);
  M5.Display.startWrite();
  if (g_pendingDead) {
    char m;
    switch (g_pendingDead) {
      case 'u': m = (char)0xA8; break;   // diaeresis
      case 'e': m = (char)0xB4; break;   // acute
      case 'i': m = '^';        break;   // circumflex (incl. Esperanto)
      case 'n': m = '~';        break;   // tilde
      case 'b': m = 'b';        break;   // breve (no standalone glyph)
      default:  m = '`';        break;   // grave
    }
    M5.Display.fillRect(x, y, charW, lineH - 4, TFT_BLACK);
    M5.Display.setFont(bodyFont());
    M5.Display.setTextColor(TFT_WHITE, TFT_BLACK);
    M5.Display.setTextDatum(m5gfx::top_left);
    M5.Display.drawString(drawable(String(m)), x, y);
    M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  } else {
    M5.Display.fillRect(x, y, charW, lineH - 4, TFT_WHITE);
    drawCaret(r, g_caretCol);
  }
  M5.Display.endWrite();
}

void renderEditor(bool full) {
  M5.Display.setFont(bodyFont());
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  M5.Display.setTextDatum(m5gfx::top_left);

  bool scrolled = (topLine != prevTopLine);

  if (full || scrolled) {
    if (needDeghost) { M5.Display.setEpdMode(m5gfx::epd_quality); needDeghost = false; partialCount = 0; }
    else             { M5.Display.setEpdMode(m5gfx::epd_fast); }

    M5.Display.startWrite();
    // Fill from statusH, not textY: the few pixel rows between the bar and
    // the text area otherwise keep fragments of whatever screen came before
    // (ghost battery icons, menu row bottoms - see the seam artifacts).
    M5.Display.fillRect(0, statusH, W, H - statusH, TFT_WHITE);
    drawStatusBar();
    M5.Display.setFont(bodyFont());
    M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
    M5.Display.setTextDatum(m5gfx::top_left);
    for (int r = 0; r < g_rows; r++) {
      int idx = topLine + r;
      String content = (idx < (int)g_lines.size()) ? lineStr(idx) : String();
      if (idx < (int)g_lines.size()) M5.Display.drawString(drawable(content), textX, textY + r * lineH);
      if (idx == g_caretRow) drawCaret(r, g_caretCol);
      prevVisible[r] = content;
    }
    M5.Display.endWrite();
    prevTopLine = topLine; prevCaretRow = g_caretRow;
    prevModified = modified;
    return;
  }

  // ---- incremental: only redraw rows whose text or caret changed ----
  M5.Display.setEpdMode(m5gfx::epd_fast);
  M5.Display.startWrite();
  if (prevModified != modified) {              // only the "*" marker needs the bar
    drawStatusBar();
    prevModified = modified;
    M5.Display.setFont(bodyFont());
    M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
    M5.Display.setTextDatum(m5gfx::top_left);
  }
  int prevCaretScreen = prevCaretRow - topLine;
  int caretScreen     = g_caretRow  - topLine;

  // Fast path: characters were APPENDED at the end of the caret row and no
  // other row changed - the overwhelmingly common case while typing. Repaint
  // only the new cells (a couple of character widths of e-ink) instead of a
  // full-width line stripe. Deletions and mid-line edits shift the tail of
  // the line, so they fall through to the per-line repaint below.
  if (caretScreen == prevCaretScreen && caretScreen >= 0 && caretScreen < g_rows) {
    int idx = topLine + caretScreen;
    String content = (idx < (int)g_lines.size()) ? lineStr(idx) : String();
    const String &prev = prevVisible[caretScreen];
    bool append = (int)content.length() > (int)prev.length() &&
                  g_caretCol == (int)content.length() &&
                  content.startsWith(prev);
    for (int r = 0; append && r < g_rows; r++) {
      if (r == caretScreen) continue;
      int i2 = topLine + r;
      String c2 = (i2 < (int)g_lines.size()) ? lineStr(i2) : String();
      if (c2 != prevVisible[r]) append = false;
    }
    if (append) {
      int oldLen = prev.length();
      int x0 = textX + oldLen * charW;
      int y  = textY + caretScreen * lineH;
      M5.Display.fillRect(x0, y, ((int)content.length() - oldLen) * charW + 4, lineH, TFT_WHITE);
      M5.Display.drawString(drawable(content.substring(oldLen)), x0, y);
      drawCaret(caretScreen, g_caretCol);
      prevVisible[caretScreen] = content;
      M5.Display.endWrite();
      prevCaretRow = g_caretRow;
      if (++partialCount >= DEGHOST_EVERY) { needDeghost = true; renderEditor(true); }
      return;
    }
  }

  for (int r = 0; r < g_rows; r++) {
    int idx = topLine + r;
    String content = (idx < (int)g_lines.size()) ? lineStr(idx) : String();
    bool dirty = (content != prevVisible[r]) || (r == prevCaretScreen) || (r == caretScreen);
    if (dirty) {
      M5.Display.fillRect(textX, textY + r * lineH, W - textX, lineH, TFT_WHITE);
      if (idx < (int)g_lines.size()) M5.Display.drawString(drawable(content), textX, textY + r * lineH);
      if (idx == g_caretRow) drawCaret(r, g_caretCol);
      prevVisible[r] = content;
    }
  }
  M5.Display.endWrite();
  prevCaretRow = g_caretRow;

  if (++partialCount >= DEGHOST_EVERY) { needDeghost = true; renderEditor(true); }
}

void ensureVisible() {
  if (g_caretRow < topLine)            topLine = g_caretRow;
  if (g_caretRow >= topLine + g_rows)  topLine = g_caretRow - g_rows + 1;
  if (topLine < 0) topLine = 0;
}

void enterEditor() {
  g_state = ST_EDIT;
  M5.Display.setFont(bodyFont());
  layout();
  caretRowCol(cursorPos, g_caretRow, g_caretCol);
  ensureVisible();
  needDeghost = true;
  prevTopLine = -1;
  prevVisible.assign(g_rows, String("\x01"));
  renderEditor(true);
}

void resumeEditor() {
  g_state = ST_EDIT;
  needDeghost = true;
  prevTopLine = -1;
  prevVisible.assign(g_rows, String("\x01"));
  layout();
  caretRowCol(cursorPos, g_caretRow, g_caretCol);
  ensureVisible();
  renderEditor(true);
}

// recompute caret + scroll + draw after an edit or cursor move
int g_edPage = 1;                    // page shown in the status bar
void afterChange(bool relayout) {
  if (relayout) layout();
  caretRowCol(cursorPos, g_caretRow, g_caretCol);
  ensureVisible();
  renderEditor(false);
  int pg = g_caretRow / g_rows + 1;  // refresh the bar's page counter on change
  if (pg != g_edPage) { g_edPage = pg; refreshStatusBar(); }
}

// =========================================================================
//  Editing operations
// =========================================================================
// Auto-save when a paragraph ends (Enter), at most once per NL_SAVE_MS so a
// large file doesn't stall on every keystroke. Named files only.
const unsigned long NL_SAVE_MS = 5000;   // 0 disables newline auto-save
unsigned long g_lastNlSave = 0;
void newlineAutosave() {
  if (NL_SAVE_MS == 0 || filename.length() == 0 || !modified) return;
  if (millis() - g_lastNlSave < NL_SAVE_MS) return;
  g_lastNlSave = millis();
  saveFile();
  renderEditor(false);                   // clear the unsaved "*"
}

void insertStr(const String &s) {
  // docReplace updates the buffer, word count and line wrap in one pass;
  // the layout work is already done, so afterChange must not re-layout.
  cursorPos += docReplace(cursorPos, 0, s.c_str(), (int)s.length());
  modified = true; desiredCol = -1;
  afterChange(false);
}
void insertChar(char c) { insertStr(String(c)); }

void deleteBack() {
  if (cursorPos <= 0) return;
  docReplace(cursorPos - 1, 1, nullptr, 0);
  cursorPos--; modified = true; desiredCol = -1;
  afterChange(false);
}
void deleteForward() {
  if (cursorPos >= (int)doc.length()) return;
  docReplace(cursorPos, 1, nullptr, 0);
  modified = true; desiredCol = -1;
  afterChange(false);
}

// Word-wise deletes (Shift/Ctrl + Backspace/Delete). Each is a single
// docReplace, so one Ctrl+Z brings the whole word back.
void deleteWordBack() {
  int p = wordLeftPos(cursorPos);
  if (p >= cursorPos) return;
  docReplace(p, cursorPos - p, nullptr, 0);
  cursorPos = p; modified = true; desiredCol = -1;
  afterChange(false);
}
void deleteWordForward() {
  int e = wordRightPos(cursorPos);
  if (e <= cursorPos) return;
  docReplace(cursorPos, e - cursorPos, nullptr, 0);
  modified = true; desiredCol = -1;
  afterChange(false);
}
void moveLeft()  { if (cursorPos > 0) cursorPos--; desiredCol = -1; afterChange(false); }
void moveRight() { if (cursorPos < (int)doc.length()) cursorPos++; desiredCol = -1; afterChange(false); }
void moveUp() {
  int row, col; caretRowCol(cursorPos, row, col);
  if (desiredCol < 0) desiredCol = col;
  if (row > 0) cursorPos = posFromRowCol(row - 1, desiredCol);
  else { cursorPos = 0; desiredCol = -1; }               // top line: its start
  afterChange(false);
}
void moveDown() {
  int row, col; caretRowCol(cursorPos, row, col);
  if (desiredCol < 0) desiredCol = col;
  if (row < (int)g_lines.size() - 1) cursorPos = posFromRowCol(row + 1, desiredCol);
  else {                                                 // bottom line: its end
    cursorPos = g_lines[row].start + g_lines[row].len;
    desiredCol = -1;
  }
  afterChange(false);
}
void moveHome() { int row, col; caretRowCol(cursorPos, row, col); cursorPos = g_lines[row].start; desiredCol = -1; afterChange(false); }
void moveEnd()  { int row, col; caretRowCol(cursorPos, row, col); cursorPos = g_lines[row].start + g_lines[row].len; desiredCol = -1; afterChange(false); }

void handleEditKey(uint8_t ascii, uint8_t keycode, uint8_t modifier) {
  // Ctrl = either Ctrl bit OR either GUI (Cmd/Win) bit: keyboards with a
  // Mac/Windows switch send Cmd from the ctrl position in Mac mode, and
  // there's no operating system here to claim Cmd for itself.
  bool ctrl = (modifier & (0x11 | 0x88)) != 0;
  bool alt  = (modifier & 0x44) != 0;          // Option / Alt

  // macOS-style composition (needs the Latin-1 fonts to display the result).
  if (g_pendingDead && !ctrl) {                // second key of a composition
    char dk = g_pendingDead;
    g_pendingDead = 0;
    if (!alt && ascii >= 32 && ascii < 127) {
      uint8_t o = composeChar(dk, (char)ascii);
      if (o) { insertChar((char)o); return; }  // the insert repaints the cell
    }
    drawPendingAccent();                       // clear the accent marker...
    // ...then fall through: the key acts normally
  }
  if (alt && !ctrl && g_keepLatin1 && ascii >= 32 && ascii < 127) {
    if (composeDead((char)ascii)) {
      g_pendingDead = (char)ascii;
      drawPendingAccent();                     // show the waiting accent
      return;
    }
    uint8_t o = optionChar((char)ascii);
    if (o) insertChar((char)o);
    return;                                    // unknown Option combo: swallow
  }
  // Shortcuts are layout-aware: kl is the letter this key TYPES (so Ctrl+W
  // is w-as-typed on Dvorak/Colemak, not the physical QWERTY position).
  char kl = keyLetter(keycode);
  if (ctrl && kl == 's') {                     // Ctrl+S quick save
    if (filename.length() == 0) enterPrompt(PM_SAVENEW, 0, "");
    else { saveFile(); renderEditor(false); }
    return;
  }
  if (ctrl && kl == 'w') { enterCount(); return; }         // Ctrl+W word count
  if (ctrl && kl == 'z') {                     // Ctrl+Z undo
    int p = undoLast();
    if (p >= 0) {
      if (p > (int)doc.length()) p = doc.length();
      cursorPos = p; modified = true; desiredCol = -1;
      afterChange(false);
    }
    return;
  }
  if (ctrl && kl == 'g') { enterGoal(); return; }          // Ctrl+G goal / sprint
  if (ctrl && kl == 'k') { enterSpell(); return; }         // Ctrl+K spell check
  if (ctrl && kl == 'p') {                     // Ctrl+P: go to page
    enterPrompt(PM_GOPAGE, 0, "");
    return;
  }
  if (ctrl && kl == 'f' && !g_focus) {                     // Ctrl+F find
    enterPrompt(PM_SEARCH, 0, g_searchTerm);
    return;
  }
  // Focus mode: draft forward only - no cursor movement, no forward delete.
  if (g_focus) {
    switch (keycode) {
      case KC_LEFT: case KC_RIGHT: case KC_UP: case KC_DOWN:
      case KC_HOME: case KC_END: case KC_DELETE: case KC_PGUP: case KC_PGDN:
        return;
    }
  }
  if (ctrl && keycode == KC_HOME) { cursorPos = 0;            desiredCol = -1; afterChange(false); return; }
  if (ctrl && keycode == KC_END)  { cursorPos = doc.length(); desiredCol = -1; afterChange(false); return; }
  // Ctrl+A / Ctrl+E: start / end of the current paragraph (macOS/emacs style)
  if (ctrl && kl == 'a') {
    while (cursorPos > 0 && doc[cursorPos - 1] != '\n') cursorPos--;
    desiredCol = -1; afterChange(false); return;
  }
  if (ctrl && kl == 'e') {
    int n = doc.length();
    while (cursorPos < n && doc[cursorPos] != '\n') cursorPos++;
    desiredCol = -1; afterChange(false); return;
  }
  // Word-wise: Shift (or Ctrl) + arrows jump a word; + Backspace/Delete
  // remove a word. (Focus mode already filtered the movement keys above.)
  bool wordMod = ((modifier & 0x22) != 0) || ctrl;   // any shift, or ctrl
  if (wordMod && keycode == KC_LEFT)   { cursorPos = wordLeftPos(cursorPos);  desiredCol = -1; afterChange(false); return; }
  if (wordMod && keycode == KC_RIGHT)  { cursorPos = wordRightPos(cursorPos); desiredCol = -1; afterChange(false); return; }
  if (wordMod && keycode == KC_BKSP)   { deleteWordBack();    return; }
  if (wordMod && keycode == KC_DELETE) { deleteWordForward(); return; }
  switch (keycode) {
    case KC_ESC:    enterEditMenu();  return;
    case KC_LEFT:   moveLeft();       return;
    case KC_RIGHT:  moveRight();      return;
    case KC_UP:     moveUp();         return;
    case KC_DOWN:   moveDown();       return;
    case KC_HOME:   moveHome();       return;
    case KC_END:    moveEnd();        return;
    case KC_PGUP: case KC_PGDN: {                // move a full screen of text
      int row, col;
      caretRowCol(cursorPos, row, col);
      if (desiredCol < 0) desiredCol = col;
      cursorPos = posFromRowCol(row + (keycode == KC_PGDN ? g_rows : -g_rows), desiredCol);
      afterChange(false);
      return;
    }
    case KC_DELETE: deleteForward();  return;
    case KC_BKSP:   deleteBack();     return;
    case KC_TAB:    insertStr("  ");  return;
    case KC_ENTER:  insertChar('\n'); newlineAutosave(); return;
  }
  if (ascii == 8)  { deleteBack(); return; }                 // backspace (if ascii-coded)
  if (ascii == 9)  { insertStr("  "); return; }              // tab -> 2 spaces
  if (ascii == 10 || ascii == 13) { insertChar('\n'); newlineAutosave(); return; }
  if (ascii >= 32 && ascii < 127)  { insertChar((char)ascii); return; }
}

// =========================================================================
//  Main menu (folder browser)
// =========================================================================
String entryLabel(const MenuEntry &e) {
  switch (e.type) {
    case E_MOVEHERE:   return "[ Move \"" + baseName(g_moveSrc) + "\" here ]";
    case E_MOVECANCEL: return String("[ Cancel move ]");
    case E_CONTINUE: return "[ Continue: " + baseName(g_lastFile) + " ]";
    case E_NEWFILE: return String("[ New file ]");
    case E_NEWDIR:  return String("[ New folder ]");
    case E_UP:      return String("../  (up one folder)");
    case E_DIR:     return e.name + "/";       // drawn bold - see drawMenuRow
    case E_FILE:    return e.name;
  }
  return String();
}

// One list row (used by the full draw and by selection moves). Fills its own
// background so it can repaint over a previously selected (black) row.
void drawMenuRow(int idx, bool sel) {
  int r = idx - menuTop;
  if (r < 0 || r >= g_mVisible || idx >= (int)g_entries.size()) return;
  int y = g_mListTop + r * g_mItemH;
  // Folders are bold (same monospace metrics), files regular - a clearer
  // distinction than a prefix character.
  EntryType t = g_entries[idx].type;
  bool boldRow = (t == E_DIR || t == E_UP);
  M5.Display.setFont(boldRow ? &fonts::FreeMonoBold12pt7b : &fonts::FreeMono12pt7b);
  M5.Display.setTextDatum(m5gfx::top_left);
  M5.Display.fillRect(MARGIN_X - 6, y - 2, W - 2 * MARGIN_X + 12, g_mItemH,
                      sel ? TFT_BLACK : TFT_WHITE);
  M5.Display.setTextColor(sel ? TFT_WHITE : TFT_BLACK, sel ? TFT_BLACK : TFT_WHITE);
  M5.Display.drawString(entryLabel(g_entries[idx]), MARGIN_X, y);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
}

bool g_menuFastOnce = false;   // next full drawMenu may use epd_fast (paging)
int  g_menuFastCount = 0;      // fast menu updates since the last clean draw

// ---- button rows: labels, drawing, keyboard focus, activation -------------
int g_btnSel = -1;             // -1 = focus in the list; 0..4 row 1, 5..9 row 2

String menuBtnLabel(int row, int i) {
  if (row == 1) switch (i) {
    case 0: return String("Layout: ") + LAYOUT_NAMES[g_layout];
    case 1: return ENABLE_BLE_KEYBOARD ? String("BT: ") + bleStatusStr() : String("");
    case 2: return String("Font size: ") +
                   ((g_fontSize == 0) ? "S" : (g_fontSize == 2) ? "L" : "M");
    case 3: return String("WiFi export");
    case 4: return String("Stats");
  } else switch (i) {
    case 0: return ENABLE_USB_DRIVE ? String("USB drive") : String("");
    case 1: return String("Cloud sync");
    case 2: return String("Sleep");
    case 3: return String("Help");
    case 4: return g_portrait ? String("Read: portrait") : String("Read: wide");
  }
  return String();
}

// Inverted = keyboard focus, or the moment it's pressed (tap or Enter) - the
// "pushed" look stays up while a slow action (WiFi, sync...) gets going.
void drawMenuBtn(int row, int i, bool inv) {
  String lbl = menuBtnLabel(row, i);
  if (!lbl.length()) return;                   // slot compiled out
  int x = g_mBtnX[i], y = (row == 1) ? g_mBtnY : g_mBtn2Y;
  M5.Display.setFont(&fonts::FreeMono9pt7b);
  M5.Display.setTextDatum(m5gfx::top_left);
  M5.Display.fillRect(x, y, g_mBtnW, g_mBtnH, inv ? TFT_BLACK : TFT_WHITE);
  M5.Display.drawRect(x, y, g_mBtnW, g_mBtnH, TFT_BLACK);
  M5.Display.setTextColor(inv ? TFT_WHITE : TFT_BLACK, inv ? TFT_BLACK : TFT_WHITE);
  M5.Display.drawString(lbl, x + 8, y + 8);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
}

bool menuBtnValid(int b) {
  if (b < 0 || b >= 2 * MB_COUNT) return false;
  return menuBtnLabel(b < MB_COUNT ? 1 : 2, b % MB_COUNT).length() > 0;
}

void menuBtnPaint(int b, bool inv) {
  if (b >= 0) drawMenuBtn(b < MB_COUNT ? 1 : 2, b % MB_COUNT, inv);
}

// Move keyboard focus between the list and a button (fast, no flash).
void menuBtnFocus(int b) {
  int old = g_btnSel;
  g_btnSel = b;
  M5.Display.setEpdMode(m5gfx::epd_fast);
  M5.Display.startWrite();
  menuBtnPaint(old, false);
  menuBtnPaint(b, true);
  drawMenuRow(g_sel, b < 0);                   // list highlight follows focus
  M5.Display.endWrite();
}

void menuBtnMove(int dx, int dy) {
  int col = g_btnSel % MB_COUNT;
  bool top = g_btnSel < MB_COUNT;
  if (dy != 0) {
    if (dy > 0 && !top) { menuBtnFocus(-1); return; }   // down into the list
    if (dy < 0 && top) return;                          // already on the top row
    int base = top ? MB_COUNT : 0, nb = -1;             // the other row, same-ish column
    for (int off = 0; off < MB_COUNT && nb < 0; off++) {
      if (col - off >= 0 && menuBtnValid(base + col - off)) nb = base + col - off;
      else if (col + off < MB_COUNT && menuBtnValid(base + col + off)) nb = base + col + off;
    }
    if (nb >= 0) menuBtnFocus(nb);
    return;
  }
  int lo = top ? 0 : MB_COUNT, hi = lo + MB_COUNT - 1, nb = g_btnSel + dx;
  while (nb >= lo && nb <= hi && !menuBtnValid(nb)) nb += dx;
  if (nb >= lo && nb <= hi) menuBtnFocus(nb);
}

// Press a button: show it pushed at once, then run the action. Toggles redraw
// the (updated) menu themselves; screen-changing actions replace the view.
void menuBtnActivate(int b) {
  if (!menuBtnValid(b)) return;
  M5.Display.setEpdMode(m5gfx::epd_fast);
  M5.Display.startWrite();
  menuBtnPaint(b, true);
  M5.Display.endWrite();
  int i = b % MB_COUNT;
  if (b < MB_COUNT) switch (i) {
    case 0: g_menuFastOnce = true; toggleLayout(); break;
    case 1: if (ENABLE_BLE_KEYBOARD) enterBtPair(); break;
    case 2: g_menuFastOnce = true; toggleFont(); break;
    case 3: enterExport(); break;
    case 4: enterStats(); break;
  } else switch (i) {
    case 0: if (ENABLE_USB_DRIVE) enterUsbDrive(); break;
    case 1: enterSync(); break;
    case 2: goStandby(); break;
    case 3: enterHelp(); break;
    case 4: g_menuFastOnce = true; toggleReaderRot(); break;
  }
}

// Move the selection: same page = repaint just the two affected rows in fast
// mode (no flash); crossing a page boundary = full redraw, also fast.
void menuMoveSel(int to) {
  if (to < 0 || to >= (int)g_entries.size() || to == g_sel) return;
  int from = g_sel;
  g_sel = to;
  if (++g_menuFastCount >= MENU_QUALITY_EVERY) {         // periodic clean draw
    g_menuFastCount = 0;
    drawMenu();
    return;
  }
  if (to < menuTop || to >= menuTop + g_mVisible) {      // page flip
    g_menuFastOnce = true;
    drawMenu();
    return;
  }
  M5.Display.setEpdMode(m5gfx::epd_fast);
  M5.Display.startWrite();
  drawMenuRow(from, false);
  drawMenuRow(to, true);
  M5.Display.endWrite();
}

void drawMenu() {
  g_state = ST_MENU;
  M5.Display.setEpdMode(g_menuFastOnce ? m5gfx::epd_fast : m5gfx::epd_quality);
  g_menuFastOnce = false;
  M5.Display.startWrite();
  M5.Display.fillScreen(TFT_WHITE);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  M5.Display.setTextDatum(m5gfx::top_left);

  M5.Display.setFont(&fonts::FreeMonoBold18pt7b);
  M5.Display.drawString("BYOBYOK", MARGIN_X, 16);

  // battery indicator (top-right)
  drawBatteryCluster(W - MARGIN_X, 18, 17);

  // current folder + hint (move mode gets its own banner)
  M5.Display.drawString(String("Folder: ") + g_cwd, MARGIN_X, 52);
  if (g_moveSrc.length())
    M5.Display.drawString(g_moveMsg.length() ? g_moveMsg
                            : "Moving \"" + baseName(g_moveSrc) +
                              "\": open the target folder, then [ Move here ]. ESC = cancel",
                          MARGIN_X, 70);
  else if (g_kbConnected)
    M5.Display.drawString("Up/Dn + Enter, or tap.  r rename   m move   Del delete   j journal   ? help",
                          MARGIN_X, 70);
  else
    M5.Display.drawString("Reader mode - tap to open folders / read files.",
                          MARGIN_X, 70);

  // two button rows (tappable, and arrow-navigable from the top of the list)
  g_mBtnY = 88; g_mBtn2Y = 124; g_mBtnH = 30;
  for (int i = 0; i < MB_COUNT; i++) {
    g_mBtnX[i] = MARGIN_X + i * (g_mBtnW + 12);
    drawMenuBtn(1, i, g_btnSel == i);
    drawMenuBtn(2, i, g_btnSel == MB_COUNT + i);
  }

  // list
  M5.Display.setFont(&fonts::FreeMono12pt7b);
  g_mItemH   = M5.Display.fontHeight() + 8;
  g_mListTop = 164;                            // below both button rows
  int footerH = 44;
  int total   = (int)g_entries.size();
  g_mVisible  = (H - g_mListTop - footerH - 6) / g_mItemH;
  if (g_mVisible < 1) g_mVisible = 1;
  g_mScrollable = total > g_mVisible;
  g_mFooterY = H - footerH;

  if (g_sel < menuTop)                menuTop = g_sel;
  if (g_sel >= menuTop + g_mVisible)  menuTop = g_sel - g_mVisible + 1;
  if (menuTop < 0) menuTop = 0;

  for (int r = 0; r < g_mVisible && (menuTop + r) < total; r++)
    drawMenuRow(menuTop + r, (menuTop + r) == g_sel && g_btnSel < 0);

  // touch paging footer (only when the list overflows one screen)
  if (g_mScrollable) {
    M5.Display.drawFastHLine(0, g_mFooterY, W, TFT_BLACK);
    M5.Display.drawFastVLine(W / 2, g_mFooterY, footerH, TFT_BLACK);
    M5.Display.setFont(&fonts::FreeMono12pt7b);
    M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
    M5.Display.setTextDatum(m5gfx::middle_center);
    M5.Display.drawString("< Prev", W / 4,     g_mFooterY + footerH / 2);
    M5.Display.drawString("Next >", W * 3 / 4, g_mFooterY + footerH / 2);
    M5.Display.setTextDatum(m5gfx::top_left);
  }
  M5.Display.endWrite();
}

void toggleLayout();   // defined with the persistence helpers

// Do the action for a menu entry. edit=true (keyboard Enter) opens files in the
// editor; edit=false (touch) opens them in the reader.
void activate(int idx, bool edit) {
  if (idx < 0 || idx >= (int)g_entries.size()) return;
  const MenuEntry e = g_entries[idx];
  switch (e.type) {
    case E_MOVEHERE:   moveDrop(); break;
    case E_MOVECANCEL: gotoMenu(); break;      // gotoMenu clears the move state
    case E_CONTINUE:
      if (edit && g_kbConnected) openForEditing(g_lastFile);
      else readerOpen(g_lastFile, g_lastPos);   // touch = read at reading place
      break;
    case E_NEWFILE: if (g_kbConnected) newFile();                      else drawMenu(); break;
    case E_NEWDIR:  if (g_kbConnected) enterPrompt(PM_NEWDIR, 0, "");  else drawMenu(); break;
    case E_UP:      cdUp();          break;
    case E_DIR:     cdInto(e.name);  break;
    case E_FILE:    if (g_moveSrc.length()) break;               // just context
                    if (edit) openFile(e.name); else openForReading(e.name); break;
  }
}

// Touch in the menu: layout button, footer paging, then a row.
void menuTap(int x, int y) {
  int row = 0;
  if (y >= g_mBtnY && y <= g_mBtnY + g_mBtnH) row = 1;
  else if (y >= g_mBtn2Y && y <= g_mBtn2Y + g_mBtnH) row = 2;
  if (row) {
    for (int i = 0; i < MB_COUNT; i++) {
      if (x < g_mBtnX[i] || x > g_mBtnX[i] + g_mBtnW) continue;
      menuBtnActivate((row == 1 ? 0 : MB_COUNT) + i);   // incl. pressed feedback
      return;
    }
    return;
  }
  int total = (int)g_entries.size();
  if (g_mScrollable && y >= g_mFooterY) {
    if (x < W / 2) { g_sel -= g_mVisible; if (g_sel < 0) g_sel = 0; }
    else           { g_sel += g_mVisible; if (g_sel > total - 1) g_sel = total - 1; }
    if (++g_menuFastCount < MENU_QUALITY_EVERY) g_menuFastOnce = true;
    else g_menuFastCount = 0;                  // periodic clean draw
    drawMenu();
    return;
  }
  if (y < g_mListTop) return;
  int r = (y - g_mListTop) / g_mItemH;
  if (r < 0 || r >= g_mVisible) return;
  int idx = menuTop + r;
  if (idx < 0 || idx >= total) return;
  g_sel = idx;
  activate(idx, false);          // touch = read / navigate
}

void gotoMenu() {
  sessionEnd();                    // log this session's words (if any)
  saveResume();                    // remember file + caret for [ Continue ]
  clearDoc();                      // so a later standby won't re-save the buffer
  g_goalMode = 0; g_goalHit = false;
  g_moveSrc = ""; g_moveMsg = "";  // abandon any half-finished move
  g_btnSel = -1;                   // fresh menu: focus starts in the list
  applyRotation(false);            // menu is always landscape
  filename = ""; modified = false; cursorPos = 0; desiredCol = -1;
  buildEntries(); g_sel = 0; menuTop = 0; drawMenu();
}

void handleMenuKey(uint8_t ascii, uint8_t keycode) {
  int total = (int)g_entries.size();
  bool onFile = (g_btnSel < 0 && g_sel >= 0 && g_sel < total && g_entries[g_sel].type == E_FILE);
  if (g_moveSrc.length()) {                    // move mode: navigate + drop only
    if (keycode == KC_ESC) { gotoMenu(); return; }
    if (keycode == KC_UP)        menuMoveSel(g_sel - 1);
    else if (keycode == KC_DOWN) menuMoveSel(g_sel + 1);
    else if (ascii == 10 || ascii == 13 || keycode == KC_ENTER) activate(g_sel, true);
    return;
  }
  if (g_btnSel >= 0) {                         // focus is on the button rows
    if (keycode == KC_ESC)   { menuBtnFocus(-1); return; }
    if (keycode == KC_LEFT)  { menuBtnMove(-1, 0); return; }
    if (keycode == KC_RIGHT) { menuBtnMove(+1, 0); return; }
    if (keycode == KC_UP)    { menuBtnMove(0, -1); return; }
    if (keycode == KC_DOWN)  { menuBtnMove(0, +1); return; }
    if (ascii == 10 || ascii == 13 || keycode == KC_ENTER) { menuBtnActivate(g_btnSel); return; }
  } else if (keycode == KC_UP) {
    if (g_sel > 0) { menuMoveSel(g_sel - 1); return; }
    int b = MB_COUNT;                          // top of the list: climb into row 2
    while (b < 2 * MB_COUNT && !menuBtnValid(b)) b++;
    if (menuBtnValid(b)) menuBtnFocus(b);
    return;
  }
  else if (keycode == KC_DOWN) menuMoveSel(g_sel + 1);
  else if (ascii == 10 || ascii == 13 || keycode == KC_ENTER) { activate(g_sel, true); }
  else if (onFile && (ascii == 'r' || ascii == 'R')) {
    enterPrompt(PM_RENAME, 0, g_entries[g_sel].name);
  }
  else if (onFile && (ascii == 'm' || ascii == 'M')) {   // start a move
    g_moveSrc = fullPath(g_entries[g_sel].name);
    g_moveMsg = "";
    g_sel = 0; menuTop = 0; buildEntries(); drawMenu();
  }
  else if (onFile && (keycode == KC_DELETE || ascii == 'd' || ascii == 'D')) {
    enterConfirmDelete(g_entries[g_sel].name);
  }
  else if (ascii == 'e' || ascii == 'E') enterExport();
  else if (ascii == 'b' || ascii == 'B') { if (ENABLE_BLE_KEYBOARD) enterBtPair(); }
  else if (ascii == 'j' || ascii == 'J') openJournal();
  else if (ascii == 's' || ascii == 'S') enterStats();
  else if (ascii == 'c' || ascii == 'C') enterSync();
  else if (ascii == 'u' || ascii == 'U') { if (ENABLE_USB_DRIVE) enterUsbDrive(); }
  else if (ascii == 'z' || ascii == 'Z') goStandby();
  else if (ascii == '?')                 enterHelp();
}

// =========================================================================
//  In-editor menu (ESC)
// =========================================================================
// Each row shows its shortcut letter on the right, so the keys are
// discoverable on-screen instead of memorized.
const int EM_COUNT = 6;
String emLabel(int i) {
  switch (i) {
    case 0: return String("Resume editing            Esc");
    case 1: return String("Save                        s");
    case 2: return String("Save & exit to menu         w");
    case 3: return String("Discard & exit to menu      d");
    case 4: return g_focus ? String("Focus mode: ON              f")
                           : String("Focus mode: off             f");
    case 5: return String("Sleep (save, power off)     z");
  }
  return String();
}

void drawEditMenu() { drawModalList("Menu", 600, 430, emLabel, EM_COUNT, g_emSel); }

void enterEditMenu() { g_state = ST_EDITMENU; g_emSel = 0; drawEditMenu(); }

// Tap on a row = pick it; tap outside the dialog = resume editing.
void editMenuTap(int x, int y) {
  int r = modalListHit(x, y);
  if (r == -1) { resumeEditor(); return; }
  if (r >= 0) doEditMenuAction(r);
}

void doEditMenuAction(int a) {
  switch (a) {
    case 0: resumeEditor(); break;
    case 1: if (filename.length() == 0) enterPrompt(PM_SAVENEW, 0, ""); else { saveFile(); resumeEditor(); } break;
    case 2: if (filename.length() == 0) enterPrompt(PM_SAVENEW, 1, ""); else { saveFile(); gotoMenu();    } break;
    case 3: gotoMenu(); break;
    case 4:                                    // toggle focus mode
      g_focus = !g_focus;
      if (g_focus) { cursorPos = doc.length(); desiredCol = -1; }
      resumeEditor();
      break;
    case 5: goStandby(); break;
  }
}

void handleEditMenuKey(uint8_t ascii, uint8_t keycode) {
  if (keycode == KC_ESC)  { resumeEditor(); return; }
  if (keycode == KC_UP)   { if (g_emSel > 0) { g_emSel--; modalListMoveSel(g_emSel + 1, g_emSel); } return; }
  if (keycode == KC_DOWN) { if (g_emSel < EM_COUNT - 1) { g_emSel++; modalListMoveSel(g_emSel - 1, g_emSel); } return; }
  if (ascii == 10 || ascii == 13 || keycode == KC_ENTER) { doEditMenuAction(g_emSel); return; }
  if (ascii == 'r' || ascii == 'R') doEditMenuAction(0);
  else if (ascii == 's' || ascii == 'S') doEditMenuAction(1);
  else if (ascii == 'w' || ascii == 'W') doEditMenuAction(2);
  else if (ascii == 'd' || ascii == 'D' || ascii == 'q' || ascii == 'Q') doEditMenuAction(3);
  else if (ascii == 'f' || ascii == 'F') doEditMenuAction(4);
  else if (ascii == 'z' || ascii == 'Z') doEditMenuAction(5);
}

// =========================================================================
//  Word count popup (Ctrl+W in the editor; any key or tap dismisses)
// =========================================================================
void drawCountPopup() {
  M5.Display.setEpdMode(m5gfx::epd_quality);
  M5.Display.startWrite();
  int bw = 560, bh = 340, bx, by;
  modalFrame(bw, bh, g_goalHit ? "Goal reached!" : "Count", bx, by);

  int screens = ((int)g_lines.size() + g_rows - 1) / g_rows;
  if (screens < 1) screens = 1;
  char l1[48], l2[48], l3[48], l4[48] = "";
  snprintf(l1, sizeof(l1), "Words:      %d", countWords());
  snprintf(l2, sizeof(l2), "Characters: %d", (int)doc.length());
  snprintf(l3, sizeof(l3), "Screens:    %d", screens);
  if (g_goalHit || g_goalMode) {               // sprint / goal progress line
    int got = g_docWords - g_goalStartWords;   if (got < 0) got = 0;
    int mins = (int)((millis() - g_goalStartMs) / 60000UL);
    if (g_goalHit || g_goalMode == 1)
      snprintf(l4, sizeof(l4), "This sprint: +%d words in %d min", got, mins);
    else
      snprintf(l4, sizeof(l4), "Goal:       %d / %d words", got, g_goalTarget);
  }
  M5.Display.setFont(&fonts::FreeMono12pt7b);
  int y = by + 90, dy = 42;
  M5.Display.drawString(l1, bx + 30, y);       y += dy;
  M5.Display.drawString(l2, bx + 30, y);       y += dy;
  M5.Display.drawString(l3, bx + 30, y);       y += dy;
  if (l4[0]) { M5.Display.drawString(l4, bx + 30, y); }

  M5.Display.setFont(&fonts::FreeMono9pt7b);
  M5.Display.drawString("Any key (or tap) to keep writing.", bx + 30, by + bh - 36);
  M5.Display.endWrite();
}

void enterCount() { g_state = ST_COUNT; drawCountPopup(); }
void dismissCount() { g_goalHit = false; resumeEditor(); }
void handleCountKey(uint8_t ascii, uint8_t keycode) {
  (void)ascii; (void)keycode;                  // any key (or tap) dismisses
  dismissCount();
}

// =========================================================================
//  Writing goal / sprint menu (Ctrl+G in the editor)
// =========================================================================
const int GOAL_COUNT = 6;
const char *GOAL_ITEMS[GOAL_COUNT] = {
  "Off", "Sprint 15 min", "Sprint 30 min",
  "Goal 250 words", "Goal 500 words", "Goal 1000 words"
};

String goalLabel(int i) { return String(GOAL_ITEMS[i]); }

void drawGoal() { drawModalList("Writing goal", 560, 420, goalLabel, GOAL_COUNT, g_goalSel); }

void enterGoal() { g_state = ST_GOAL; g_goalSel = 0; drawGoal(); }

// Tap on a row = pick it; tap outside the dialog = back to writing.
void goalTap(int x, int y) {
  int r = modalListHit(x, y);
  if (r == -1) { resumeEditor(); return; }
  if (r >= 0) applyGoal(r);
}

void applyGoal(int i) {
  switch (i) {
    case 0: g_goalMode = 0; break;
    case 1: g_goalMode = 1; g_goalTarget = 15;   break;
    case 2: g_goalMode = 1; g_goalTarget = 30;   break;
    case 3: g_goalMode = 2; g_goalTarget = 250;  break;
    case 4: g_goalMode = 2; g_goalTarget = 500;  break;
    case 5: g_goalMode = 2; g_goalTarget = 1000; break;
  }
  g_goalStartMs = millis();
  g_goalStartWords = g_docWords;
  g_goalHit = false;
  resumeEditor();
}

void handleGoalKey(uint8_t ascii, uint8_t keycode) {
  if (keycode == KC_ESC) { resumeEditor(); return; }
  if (keycode == KC_UP)   { if (g_goalSel > 0) { g_goalSel--; modalListMoveSel(g_goalSel + 1, g_goalSel); } return; }
  if (keycode == KC_DOWN) { if (g_goalSel < GOAL_COUNT - 1) { g_goalSel++; modalListMoveSel(g_goalSel - 1, g_goalSel); } return; }
  if (ascii == 10 || ascii == 13 || keycode == KC_ENTER) applyGoal(g_goalSel);
}

// =========================================================================
//  Writing stats screen ('s' in the menu) - reads /.ptstats.csv
// =========================================================================
// days-since-epoch from a civil date (Howard Hinnant's algorithm)
long dayNum(int y, int m, int d) {
  y -= m <= 2;
  long era = (y >= 0 ? y : y - 399) / 400;
  unsigned yoe = (unsigned)(y - era * 400);
  unsigned doy = (153u * (unsigned)(m + (m > 2 ? -3 : 9)) + 2) / 5 + (unsigned)d - 1;
  unsigned doe = yoe * 365 + yoe / 4 - yoe / 100 + doy;
  return era * 146097 + (long)doe - 719468;
}

void drawStats() {
  // aggregate the log: one "YYYY-MM-DD,words" line per session, chronological
  long lifetime = 0, best = 0, todayWords = 0;
  long prevDay = -1, daySum = 0, chain = 0;
  long today = -1;
  if (g_rtcOk) {
    auto dt = M5.Rtc.getDateTime();
    today = dayNum(dt.date.year, dt.date.month, dt.date.date);
  }
  File f = SD.open("/.ptstats.csv", FILE_READ);
  if (f) {
    while (f.available()) {
      String line = f.readStringUntil('\n');
      int y, m, d, w;
      if (sscanf(line.c_str(), "%d-%d-%d,%d", &y, &m, &d, &w) != 4) continue;
      long day = dayNum(y, m, d);
      if (day != prevDay) {                    // close out the previous day
        if (daySum > best) best = daySum;
        chain = (prevDay >= 0 && day == prevDay + 1) ? chain + 1 : 1;
        prevDay = day; daySum = 0;
      }
      daySum += w;
      lifetime += w;
    }
    f.close();
    if (daySum > best) best = daySum;
    if (prevDay == today) todayWords = daySum;
  }
  long streak = 0;
  if (today >= 0 && prevDay >= 0 && prevDay >= today - 1) streak = chain;

  M5.Display.setEpdMode(m5gfx::epd_quality);
  M5.Display.startWrite();
  M5.Display.fillScreen(TFT_WHITE);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  M5.Display.setTextDatum(m5gfx::top_left);
  M5.Display.setFont(&fonts::FreeMonoBold18pt7b);
  M5.Display.drawString("Writing stats", MARGIN_X, 24);

  char l1[48], l2[48], l3[48], l4[48];
  snprintf(l1, sizeof(l1), "Today:     %ld words", todayWords);
  snprintf(l2, sizeof(l2), "Streak:    %ld day%s", streak, streak == 1 ? "" : "s");
  snprintf(l3, sizeof(l3), "Best day:  %ld words", best);
  snprintf(l4, sizeof(l4), "Lifetime:  %ld words", lifetime);
  M5.Display.setFont(&fonts::FreeMono12pt7b);
  int y = 100, dy = 46;
  M5.Display.drawString(l1, MARGIN_X, y);  y += dy;
  M5.Display.drawString(l2, MARGIN_X, y);  y += dy;
  M5.Display.drawString(l3, MARGIN_X, y);  y += dy;
  M5.Display.drawString(l4, MARGIN_X, y);  y += dy;

  M5.Display.setFont(&fonts::FreeMono9pt7b);
  M5.Display.drawString("Words are logged when you leave the editor or the device sleeps.",
                        MARGIN_X, y + 14);
  M5.Display.drawString("Press any key or tap to go back.", MARGIN_X, H - 28);
  M5.Display.endWrite();
}

void enterStats() { g_state = ST_STATS; drawStats(); }
void handleStatsKey(uint8_t ascii, uint8_t keycode) {
  (void)ascii; (void)keycode;
  gotoMenu();
}

// =========================================================================
//  Spell check (Ctrl+K in the editor) - needs DICT_PATH on the SD card
// =========================================================================
const int SPELL_MAX = 100;
String g_spellWords[SPELL_MAX];
int    g_spellCounts[SPELL_MAX];
int    g_spellFound = 0;                 // -1 = no usable dictionary
int    g_spellTop = 0;
int    g_spellSel = 0;
void drawSpellRow(int i, bool sel);

// Load the word list once per power-on (kept in PSRAM afterwards). The file
// is folded through the same UTF-8 -> ASCII pipeline as documents (so
// "étude" matches a folded doc), lowercased, and re-sorted - any standard
// word list works without preprocessing.
bool dictLoad() {
  if (g_dict && !g_dictOff.empty()) return true;
  File f = SD.open(DICT_PATH, FILE_READ);
  if (!f) return false;
  int len = (int)f.size();
  int cap = len + 256;                 // folding almost always shrinks; slack for the rest
  char *buf = (char *)GB_MALLOC((size_t)cap);
  if (!buf) { f.close(); return false; }
  int out = 0;
  char chunk[512];
  Utf8Fold u8;
  while (f.available()) {
    int n = (int)f.readBytes(chunk, sizeof(chunk));
    for (int i = 0; i < n; i++) {
      long cp = u8.feed((uint8_t)chunk[i]);
      if (cp < 0) continue;
      if (cp < 0x80) { if (out < cap - 1) buf[out++] = (char)cp; continue; }
      for (const char *r = asciiFold((uint32_t)cp); *r && out < cap - 1; r++)
        buf[out++] = *r;
    }
    yield();                                   // ~2 MB list: feed the watchdog
  }
  f.close();
  buf[out] = 0;
  g_dict = buf; g_dictLen = out;
  dictIndex();
  dictNormalize();
  return !g_dictOff.empty();
}

const int SPELL_ROWS = 11;

void drawSpell() {
  M5.Display.setEpdMode(m5gfx::epd_quality);
  M5.Display.startWrite();
  M5.Display.fillScreen(TFT_WHITE);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  M5.Display.setTextDatum(m5gfx::top_left);
  M5.Display.setFont(&fonts::FreeMonoBold18pt7b);
  M5.Display.drawString("Spell check", MARGIN_X, 24);
  M5.Display.setFont(&fonts::FreeMono12pt7b);

  if (g_spellFound < 0) {
    M5.Display.drawString("No word list found.", MARGIN_X, 100);
    M5.Display.setFont(&fonts::FreeMono9pt7b);
    M5.Display.drawString("Put a plain-text dictionary at " DICT_PATH " on the SD card,",
                          MARGIN_X, 150);
    M5.Display.drawString("one word per line. Any standard list works as-is - mixed case,",
                          MARGIN_X, 174);
    M5.Display.drawString("possessives and accents are normalized automatically.",
                          MARGIN_X, 198);
  } else if (g_spellFound == 0) {
    M5.Display.drawString("No unknown words. Nice.", MARGIN_X, 100);
  } else {
    int pages = (g_spellFound + SPELL_ROWS - 1) / SPELL_ROWS;
    int pg = g_spellTop / SPELL_ROWS + 1;
    M5.Display.setFont(&fonts::FreeMono9pt7b);
    M5.Display.setTextDatum(m5gfx::top_right);
    M5.Display.drawString(String(g_spellFound) + (g_spellFound == SPELL_MAX ? "+" : "") +
                          " unknown   page " + pg + "/" + pages, W - MARGIN_X, 30);
    M5.Display.setTextDatum(m5gfx::top_left);
    for (int r = 0; r < SPELL_ROWS; r++) {
      int i = g_spellTop + r;
      if (i >= g_spellFound) break;
      drawSpellRow(i, i == g_spellSel);
    }
  }
  M5.Display.setFont(&fonts::FreeMono9pt7b);
  M5.Display.drawString("Up/Down select   Enter = jump to it   l = learn (add to word list)   ESC back",
                        MARGIN_X, H - 28);
  M5.Display.endWrite();
}

void drawSpellRow(int i, bool sel) {
  int r = i - g_spellTop;
  if (r < 0 || r >= SPELL_ROWS || i >= g_spellFound) return;
  int y = 76 + r * 36;
  String line = g_spellWords[i];
  if (g_spellCounts[i] > 1) line += "   x" + String(g_spellCounts[i]);
  M5.Display.setFont(&fonts::FreeMono12pt7b);
  M5.Display.setTextDatum(m5gfx::top_left);
  M5.Display.fillRect(MARGIN_X - 6, y - 2, W - 2 * MARGIN_X + 12, 34,
                      sel ? TFT_BLACK : TFT_WHITE);
  M5.Display.setTextColor(sel ? TFT_WHITE : TFT_BLACK, sel ? TFT_BLACK : TFT_WHITE);
  M5.Display.drawString(drawable(line), MARGIN_X, y);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
}

void spellMoveSel(int to) {
  if (to < 0 || to >= g_spellFound || to == g_spellSel) return;
  int from = g_spellSel;
  g_spellSel = to;
  if (to < g_spellTop || to >= g_spellTop + SPELL_ROWS) {
    g_spellTop = (to / SPELL_ROWS) * SPELL_ROWS;
    drawSpell();
    return;
  }
  M5.Display.setEpdMode(m5gfx::epd_fast);
  M5.Display.startWrite();
  drawSpellRow(from, false);
  drawSpellRow(to, true);
  M5.Display.endWrite();
}

void enterSpell() {
  // scanning a whole novel takes a couple of seconds - say so
  M5.Display.setEpdMode(m5gfx::epd_fast);
  M5.Display.startWrite();
  M5.Display.fillRect(0, 0, W, statusH, TFT_WHITE);
  M5.Display.setFont(&fonts::FreeMono9pt7b);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  M5.Display.setTextDatum(m5gfx::top_left);
  M5.Display.drawString("Checking spelling... (first use also loads the word list)",
                        MARGIN_X, 5);
  M5.Display.endWrite();
  g_spellFound = dictLoad() ? spellScan(g_spellWords, g_spellCounts, SPELL_MAX) : -1;
  g_spellTop = 0;
  g_spellSel = 0;
  g_state = ST_SPELL;
  drawSpell();
}

void handleSpellKey(uint8_t ascii, uint8_t keycode) {
  if (keycode == KC_ESC) { resumeEditor(); return; }
  if (g_spellFound <= 0) return;
  if (keycode == KC_UP)   { spellMoveSel(g_spellSel - 1); return; }
  if (keycode == KC_DOWN) { spellMoveSel(g_spellSel + 1); return; }
  if (keycode == KC_LEFT || keycode == KC_PGUP)  { spellMoveSel(g_spellSel - SPELL_ROWS); return; }
  if (keycode == KC_RIGHT || keycode == KC_PGDN || ascii == ' ') {
    int to = g_spellSel + SPELL_ROWS;
    spellMoveSel(to >= g_spellFound ? g_spellFound - 1 : to);
    return;
  }
  if (ascii == 10 || ascii == 13 || keycode == KC_ENTER) {   // jump to the word
    int hit = searchDoc(g_spellWords[g_spellSel], 0);
    if (hit >= 0) { cursorPos = hit; desiredCol = -1; resumeEditor(); }
    return;
  }
  if (ascii == 'l' || ascii == 'L') {                        // learn the word
    String w = g_spellWords[g_spellSel];
    File f = SD.open(DICT_PATH, FILE_APPEND);
    if (f) {                       // UTF-8 on disk (Esperanto slots re-encoded)
      writeUtf8Run(f, w.c_str(), (int)w.length());
      f.print('\n');
      f.close();
    }
    dictLearn(w.c_str());
    for (int i = g_spellSel; i < g_spellFound - 1; i++) {    // drop from results
      g_spellWords[i]  = g_spellWords[i + 1];
      g_spellCounts[i] = g_spellCounts[i + 1];
    }
    g_spellFound--;
    if (g_spellSel >= g_spellFound) g_spellSel = g_spellFound > 0 ? g_spellFound - 1 : 0;
    if (g_spellTop > g_spellSel) g_spellTop = (g_spellSel / SPELL_ROWS) * SPELL_ROWS;
    drawSpell();
    return;
  }
}

void spellTap(int x, int y) {
  if (y < statusH + 20) { resumeEditor(); return; }   // top band exits
  if (x < W / 3) handleSpellKey(0, KC_LEFT);
  else           handleSpellKey(0, KC_RIGHT);
}

