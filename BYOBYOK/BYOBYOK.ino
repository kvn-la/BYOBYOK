  {0x0C,'u','U'},{0x12,'y','Y'},{0x13,';',':'},
  {0x16,'r','R'},{0x07,'s','S'},{0x09,'t','T'},{0x0A,'d','D'},
  {0x0D,'n','N'},{0x0E,'e','E'},{0x0F,'i','I'},{0x33,'o','O'},
  {0x11,'k','K'},
};

const int LAYOUT_COUNT = 3;
const char *LAYOUT_NAMES[LAYOUT_COUNT] = { "QWERTY", "DVORAK", "COLEMAK" };

char layoutChar(uint8_t kc, bool shift) {
  const DvKey *tab; int n;
  if (g_layout == 1)      { tab = DVORAK;  n = (int)(sizeof(DVORAK)  / sizeof(DVORAK[0]));  }
  else if (g_layout == 2) { tab = COLEMAK; n = (int)(sizeof(COLEMAK) / sizeof(COLEMAK[0])); }
  else return 0;
  for (int i = 0; i < n; i++) if (tab[i].kc == kc) return shift ? tab[i].hi : tab[i].lo;
  return 0;   // not remapped -> caller keeps the library ascii
}

// ==== BLEKB-CORE BEGIN ==== (extracted verbatim into tests/ - keep in sync)
// BLE HID keyboards hand us raw input reports; unlike EspUsbHost there's no
// library doing the keycode->character work, so we decode them ourselves.
// (KeyEvt / BleKbState are defined near the top, in the BLEKB-TYPES block.)

// HID usage -> ASCII, US layout. Letters honor shift^caps; symbols shift only.
char hidToAscii(uint8_t kc, bool shift, bool caps) {
  if (kc >= 0x04 && kc <= 0x1D) {                 // a..z
    char c = (char)('a' + (kc - 0x04));
    return (shift != caps) ? (char)(c - 32) : c;
  }
  if (kc >= 0x1E && kc <= 0x27) {                 // 1..9,0
    static const char base[] = "1234567890";
    static const char shf[]  = "!@#$%^&*()";
    return shift ? shf[kc - 0x1E] : base[kc - 0x1E];
  }
  switch (kc) {
    case 0x28: return 13;                         // Enter
    case 0x2A: return 8;                          // Backspace
    case 0x2B: return 9;                          // Tab
    case 0x2C: return ' ';
    case 0x2D: return shift ? '_'  : '-';
    case 0x2E: return shift ? '+'  : '=';
    case 0x2F: return shift ? '{'  : '[';
    case 0x30: return shift ? '}'  : ']';
    case 0x31: return shift ? '|'  : '\\';
    case 0x33: return shift ? ':'  : ';';
    case 0x34: return shift ? '"'  : '\'';
    case 0x35: return shift ? '~'  : '`';
    case 0x36: return shift ? '<'  : ',';
    case 0x37: return shift ? '>'  : '.';
    case 0x38: return shift ? '?'  : '/';
  }
  return 0;                                       // arrows/F-keys...: keycode only
}

// A keyboard input report lists the keys *currently held* (standard 8-byte
// format: [modifiers, reserved, k1..k6]). Diffing against the previous report
// yields the newly pressed keys. Returns the number of KeyEvt produced.
int bleKbDecode(BleKbState &st, const uint8_t *rep, int len, KeyEvt *out, int maxOut) {
  if (!rep || len < 8) return 0;
  const uint8_t *keys = rep + 2;
  for (int i = 0; i < 6; i++)
    if (keys[i] == 0x01) return 0;                // phantom/rollover: ignore whole report
  uint8_t mods = rep[0];
  int nOut = 0;
  for (int i = 0; i < 6; i++) {
    uint8_t kc = keys[i];
    if (kc < 0x04) continue;                      // 0 = no key
    bool isNew = true;
    for (int j = 0; j < 6; j++) if (st.keys[j] == kc) { isNew = false; break; }
    if (!isNew) continue;
    if (kc == 0x39) { st.caps = !st.caps; continue; }   // CapsLock toggles, no event
    if (nOut < maxOut) {
      bool shift = (mods & 0x22) != 0;            // left/right shift
      KeyEvt e;
      e.ascii = (uint8_t)hidToAscii(kc, shift, st.caps);
      e.keycode = kc;
      e.modifiers = mods;
      e.caps = st.caps;
      out[nOut++] = e;
    }
  }
  st.mods = mods;
  memcpy(st.keys, keys, 6);
  return nOut;
}
// ==== BLEKB-CORE END ====

// The letter a physical key types under the ACTIVE layout (lowercase, 0 if
// none). Shortcuts use this, so Ctrl+W is the key that TYPES 'w' on Dvorak
// or Colemak - not the physical QWERTY position.
char keyLetter(uint8_t keycode) {
  char c = (g_layout != 0) ? layoutChar(keycode, false) : 0;
  if (!c) c = hidToAscii(keycode, false, false);
  return (c >= 'a' && c <= 'z') ? c : 0;
}

// The queue that both keyboard paths (USB + BLE) feed into; loop() drains it.
QueueHandle_t g_keyQueue = nullptr;

// =========================================================================
//  Bluetooth (BLE) keyboard host - optional (see ENABLE_BLE_KEYBOARD)
// =========================================================================
#if ENABLE_BLE_KEYBOARD
void drawBtPair();

enum BleState { BLE_OFF, BLE_IDLE, BLE_SCAN_PAIR, BLE_SCAN_RECONNECT, BLE_CONNECTING, BLE_CONNECTED };
volatile BleState g_bleState = BLE_OFF;
bool     g_bleEnabled = false;             // a keyboard is paired (persisted)
bool     g_bleInited  = false;             // NimBLE stack is up
bool     g_blePairing = false;             // a pairing session is in progress
uint32_t g_blePasskey = 0;                 // code shown during pairing
String   g_bleName    = "";                // paired keyboard's name (persisted)
NimBLEClient *g_bleClient = nullptr;
NimBLEAddress g_bleFoundAddr;              // set by the scan callback...
String        g_bleFoundName = "";
volatile bool g_bleDoConnect = false;      // ...then loop() connects (main task)
volatile bool g_bleUiDirty   = false;      // BLE task asks the UI to redraw
BleKbState g_bleKeys;

bool g_bleUserOff = false;                 // paired, but radio paused (persisted)

bool bleConnected() { return g_bleState == BLE_CONNECTED; }
const char *bleStatusStr() {
  if (g_bleEnabled && g_bleUserOff) return "paused";
  switch (g_bleState) {
    case BLE_CONNECTED:  return "connected";
    case BLE_CONNECTING: return "connecting";
    case BLE_SCAN_PAIR:  return "pairing";
    case BLE_IDLE:
    case BLE_SCAN_RECONNECT: return "waiting";
    default:             return "off";
  }
}

void bleSavePrefs() {
  g_prefs.begin("paper", false);
  g_prefs.putBool("bleon", g_bleEnabled);
  g_prefs.putBool("bleoff", g_bleUserOff);
  g_prefs.putString("blename", g_bleName);
  g_prefs.end();
}

// Pause / resume Bluetooth without losing the pairing: deinit(false) keeps
// the stored bond, so resuming reconnects without re-pairing.
void bleTogglePower() {
  if (!g_bleEnabled) return;               // nothing paired: use Pair instead
  g_bleUserOff = !g_bleUserOff;
  if (g_bleUserOff) {
    if (g_bleInited) {
      NimBLEDevice::getScan()->stop();
      if (g_bleClient && g_bleClient->isConnected()) g_bleClient->disconnect();
      NimBLEDevice::deinit(false);         // radio off, bond KEPT
      g_bleInited = false;
      g_bleClient = nullptr;
    }
    g_bleState = BLE_OFF;
  } else {
    bleInit();
    g_bleState = BLE_IDLE;                 // loop() re-arms the scan
  }
  bleSavePrefs();
}

// Keys arrive on NimBLE's own task: decode and queue only - never draw here.
void bleNotifyCB(NimBLERemoteCharacteristic *chr, uint8_t *data, size_t len, bool isNotify) {
  (void)chr; (void)isNotify;
  KeyEvt evs[8];
  int n = bleKbDecode(g_bleKeys, data, (int)len, evs, 8);
  for (int i = 0; i < n && g_keyQueue; i++) xQueueSend(g_keyQueue, &evs[i], 0);
}

class BleScanCB : public NimBLEScanCallbacks {
  void onResult(const NimBLEAdvertisedDevice *adv) override {
    if (!adv->isAdvertisingService(NimBLEUUID((uint16_t)0x1812))) return;  // HID only
    if (g_bleState == BLE_SCAN_RECONNECT) {
      // A sleeping keyboard often wakes advertising a rotating private
      // address, so a strict bond-address check misses it and forces a
      // from-scratch re-pair. Accept a bonded address OR a name match; the
      // stored keys still gate the connection (encryption fails on impostors).
      bool ours = NimBLEDevice::isBonded(adv->getAddress()) ||
                  (g_bleName.length() && g_bleName == adv->getName().c_str());
      if (!ours) return;
    }
    g_bleFoundAddr = adv->getAddress();
    g_bleFoundName = adv->getName().c_str();
    NimBLEDevice::getScan()->stop();
    g_bleDoConnect = true;                       // loop() takes it from here
  }
  void onScanEnd(const NimBLEScanResults &results, int reason) override {
    (void)results; (void)reason;
    if (g_bleDoConnect) return;                  // stopped on purpose, to connect
    if (g_bleState == BLE_SCAN_PAIR) {           // 30 s pairing window ran out
      g_blePairing = false;
      g_bleState = g_bleEnabled ? BLE_IDLE : BLE_OFF;
      g_bleUiDirty = true;
    } else if (g_bleState == BLE_SCAN_RECONNECT) {
      g_bleState = BLE_IDLE;                     // loop() re-arms the scan
    }
  }
};
BleScanCB g_bleScanCB;

class BleClientCB : public NimBLEClientCallbacks {
  void onDisconnect(NimBLEClient *c, int reason) override {
    (void)c; (void)reason;                       // keyboard slept or went away
    g_bleState = g_bleEnabled ? BLE_IDLE : BLE_OFF;   // loop() re-arms the scan
    g_bleUiDirty = true;
  }
};
BleClientCB g_bleClientCB;

void bleInit() {
  if (g_bleInited) return;
  NimBLEDevice::init("BYOBYOK");
  NimBLEDevice::setSecurityAuth(true, true, true);        // bond + MITM + LE SC
  NimBLEDevice::setSecurityIOCap(BLE_HS_IO_DISPLAY_ONLY); // we show a code, kb types it
  NimBLEDevice::getScan()->setScanCallbacks(&g_bleScanCB, false);
  NimBLEDevice::getScan()->setActiveScan(true);
  g_bleInited = true;
}

void bleStartScan(bool pairMode) {
  NimBLEScan *sc = NimBLEDevice::getScan();
  if (sc->isScanning()) sc->stop();
  if (pairMode) {                                // eager scan while the user waits
    sc->setInterval(100); sc->setWindow(100);
    g_bleState = BLE_SCAN_PAIR;
    sc->start(30 * 1000, false, true);           // 30 s pairing window
  } else {                                       // sipping scan: wait for kb to wake
    sc->setInterval(2000); sc->setWindow(50);    // low duty cycle, ~1-2 mA
    g_bleState = BLE_SCAN_RECONNECT;
    sc->start(0, false, true);                   // forever (until stopped)
  }
}

void bleBeginPair() {
  bleInit();
  if (g_bleClient && g_bleClient->isConnected()) g_bleClient->disconnect();
  NimBLEDevice::deleteAllBonds();
  g_bleEnabled = false; g_bleName = "";
  g_blePairing = true;
  g_blePasskey = 100000 + (esp_random() % 900000);   // always 6 digits
  NimBLEDevice::setSecurityPasskey(g_blePasskey);
  bleStartScan(true);
}

void bleForget() {
  g_blePairing = false;
  if (g_bleInited) {
    NimBLEDevice::getScan()->stop();
    if (g_bleClient && g_bleClient->isConnected()) g_bleClient->disconnect();
    NimBLEDevice::deleteAllBonds();
    NimBLEDevice::deinit(true);                  // radio fully off again
    g_bleInited = false;
    g_bleClient = nullptr;
  }
  g_bleEnabled = false; g_bleName = "";
  g_bleState = BLE_OFF;
  bleSavePrefs();
}

// Runs on the loop() task (connecting can block for a second or two).
void bleConnectNow() {
  g_bleState = BLE_CONNECTING; g_bleUiDirty = true;
  if (!g_bleClient) {
    g_bleClient = NimBLEDevice::createClient();
    g_bleClient->setClientCallbacks(&g_bleClientCB, false);
  }
  bool ok = g_bleClient->connect(g_bleFoundAddr);
  if (ok) ok = g_bleClient->secureConnection();  // pair/bond + encrypt (HID requires it)
  NimBLERemoteService *hid = ok ? g_bleClient->getService(NimBLEUUID((uint16_t)0x1812)) : nullptr;
  int subs = 0;
  if (hid) {
    // Report-protocol input reports: 0x2A4D whose 0x2908 descriptor says "input".
    for (auto *ch : hid->getCharacteristics(true)) {
      if (ch->getUUID() != NimBLEUUID((uint16_t)0x2A4D) || !ch->canNotify()) continue;
      auto *rr = ch->getDescriptor(NimBLEUUID((uint16_t)0x2908));
      if (rr) { auto v = rr->readValue(); if (v.size() >= 2 && v[1] != 0x01) continue; }
      if (ch->subscribe(true, bleNotifyCB)) subs++;
    }
    if (subs == 0) {                             // fall back to boot protocol
      auto *pm = hid->getCharacteristic(NimBLEUUID((uint16_t)0x2A4E));
      auto *bi = hid->getCharacteristic(NimBLEUUID((uint16_t)0x2A22));
      if (pm && bi && bi->canNotify()) {
        uint8_t boot = 0;                        // 0 = boot protocol mode
        pm->writeValue(&boot, 1, false);
        if (bi->subscribe(true, bleNotifyCB)) subs++;
      }
    }
  }
  if (subs == 0) {                               // not a usable keyboard
    if (g_bleClient->isConnected()) g_bleClient->disconnect();
    g_bleState = g_bleEnabled ? BLE_IDLE : BLE_OFF;    // loop() re-arms the scan
    g_bleUiDirty = true;
    return;
  }
  g_bleKeys = BleKbState();                      // fresh key-diff state
  if (g_blePairing) {                            // first success: persist it
    g_blePairing = false;
    g_bleEnabled = true;
    g_bleName = g_bleFoundName.length() ? g_bleFoundName : String("keyboard");
    bleSavePrefs();
  }
  g_blePasskey = 0;
  g_bleState = BLE_CONNECTED;
  g_bleUiDirty = true;
}

void bleBoot() {                                 // called once from setup()
  g_prefs.begin("paper", true);
  g_bleEnabled = g_prefs.getBool("bleon", false);
  g_bleUserOff = g_prefs.getBool("bleoff", false);
  g_bleName    = g_prefs.getString("blename", "");
  g_prefs.end();
  if (g_bleEnabled && !g_bleUserOff) { bleInit(); g_bleState = BLE_IDLE; }
}

void bleLoopTick() {                             // called every loop()
  if (g_bleDoConnect) { g_bleDoConnect = false; bleConnectNow(); }
  if (g_bleEnabled && g_bleInited && g_bleState == BLE_IDLE) bleStartScan(false);
  if (g_bleUiDirty) {
    g_bleUiDirty = false;
    if (g_state == ST_BTPAIR)    drawBtPair();
    else if (g_state == ST_MENU) drawMenu();     // refresh the status label
  }
}

// ---- pairing screen (ST_BTPAIR) - fully touch-operable --------------------
const int BT_ROWS = 5;
const int BT_ROW_H = 42, BT_ROW_GAP = 8, BT_ROW_W = 560;
int g_btRowYs[BT_ROWS];                    // -1 = row not shown this draw

void drawBtPair() {
  M5.Display.setEpdMode(m5gfx::epd_quality);
  M5.Display.startWrite();
  M5.Display.fillScreen(TFT_WHITE);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  M5.Display.setTextDatum(m5gfx::top_left);
  M5.Display.setFont(&fonts::FreeMonoBold18pt7b);
  M5.Display.drawString("Bluetooth keyboard", MARGIN_X, 24);

  M5.Display.setFont(&fonts::FreeMono12pt7b);
  String nm = g_bleName.length() ? g_bleName : String("keyboard");
  String st;
  switch (g_bleState) {
    case BLE_CONNECTED:      st = "Connected: " + nm; break;
    case BLE_CONNECTING:     st = "Connecting..."; break;
    case BLE_SCAN_PAIR:      st = "Scanning - put the keyboard in pairing mode."; break;
    case BLE_IDLE:
    case BLE_SCAN_RECONNECT: st = "Paired: " + nm + "  (press any key on it to wake)"; break;
    default:                 st = "Off."; break;
  }
  M5.Display.drawString(st, MARGIN_X, 92);

  if (g_blePasskey && (g_bleState == BLE_SCAN_PAIR || g_bleState == BLE_CONNECTING)) {
    M5.Display.setFont(&fonts::FreeMono9pt7b);
    M5.Display.drawString("If the keyboard asks for a code, type this on it, then Enter:",
                          MARGIN_X, 136);
    M5.Display.setFont(&fonts::FreeMonoBold18pt7b);
    char pk[8];
    snprintf(pk, sizeof(pk), "%06u", (unsigned)g_blePasskey);
    M5.Display.drawString(pk, MARGIN_X, 166);
    M5.Display.setFont(&fonts::FreeMono12pt7b);
  }

  const char *lbl[BT_ROWS] = {
    "Pair new keyboard",
    !g_bleEnabled ? nullptr
                  : (g_bleUserOff ? "Turn Bluetooth on" : "Turn Bluetooth off (keep pairing)"),
    "Key test (shows what each key sends)",
    g_bleEnabled ? "Forget this keyboard" : nullptr,
    "Back",
  };
  int y = 244;
  for (int i = 0; i < BT_ROWS; i++) {
    g_btRowYs[i] = -1;
    if (!lbl[i]) continue;
    g_btRowYs[i] = y;
    M5.Display.drawRect(MARGIN_X, y, BT_ROW_W, BT_ROW_H, TFT_BLACK);
    M5.Display.drawString(lbl[i], MARGIN_X + 16, y + 9);
    y += BT_ROW_H + BT_ROW_GAP;
  }

  M5.Display.setFont(&fonts::FreeMono9pt7b);
  M5.Display.drawString("BLE keyboards only (Bluetooth 4/5).  p pair  o on/off  t key test  f forget  ESC back",
                        MARGIN_X, H - 26);
  M5.Display.endWrite();
}

void enterBtPair() { g_state = ST_BTPAIR; drawBtPair(); }

void btPairLeave() {
  if (g_bleInited && g_bleState == BLE_SCAN_PAIR) {   // cancel a pairing session
    g_blePairing = false;
    NimBLEDevice::getScan()->stop();
    g_bleState = g_bleEnabled ? BLE_IDLE : BLE_OFF;
  }
  gotoMenu();
}

void doBtPairAction(int i) {
  switch (i) {
    case 0: bleBeginPair(); drawBtPair(); break;
    case 1: bleTogglePower(); drawBtPair(); break;
    case 2: enterKeyTest(); break;
    case 3: if (g_bleEnabled) { bleForget(); drawBtPair(); } break;
    case 4: btPairLeave(); break;
  }
}

void handleBtPairKey(uint8_t ascii, uint8_t keycode) {
  if (keycode == KC_ESC) { btPairLeave(); return; }
  if (ascii == 'p' || ascii == 'P') { doBtPairAction(0); return; }
  if (ascii == 'o' || ascii == 'O') { doBtPairAction(1); return; }
  if (ascii == 't' || ascii == 'T') { doBtPairAction(2); return; }
  if (ascii == 'f' || ascii == 'F') { doBtPairAction(3); return; }
}

void btPairTap(int x, int y) {
  if (x < MARGIN_X || x > MARGIN_X + BT_ROW_W) return;
  for (int i = 0; i < BT_ROWS; i++) {
    if (g_btRowYs[i] < 0) continue;
    if (y >= g_btRowYs[i] && y <= g_btRowYs[i] + BT_ROW_H) { doBtPairAction(i); return; }
  }
}

