// =========================================================================
//  Standby (save + power off). Wakes with the power button (cold boot).
// =========================================================================
String autoName() {
  if (g_rtcOk) {
    auto dt = M5.Rtc.getDateTime();
    char b[32];
    snprintf(b, sizeof(b), "note-%02d%02d-%02d%02d%02d.txt",
             (int)dt.date.month, (int)dt.date.date,
             (int)dt.time.hours, (int)dt.time.minutes, (int)dt.time.seconds);
    return String(b);
  }
  return String("untitled.txt");
}

// Save the buffer if it holds unsaved work, auto-naming a brand-new file so
// nothing is ever lost. Shared by standby and the keyboard-unplug path.
void saveWorkIfAny() {
  if (modified && doc.length() > 0) {
    if (filename.length() == 0) filename = fullPath(autoName());
    saveFile();
  }
}

void goStandby() {
  g_lastActivity = millis();     // so an idle trigger can't immediately re-fire
  applyRotation(false);          // sleep screen is laid out for landscape
  saveWorkIfAny();
  sessionEnd();                    // log words + remember the resume point
  saveResume();
  // E-ink keeps this image while powered off, so leave a helpful message.
  M5.Display.setEpdMode(m5gfx::epd_quality);
  M5.Display.startWrite();
  M5.Display.fillScreen(TFT_WHITE);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  M5.Display.setTextDatum(m5gfx::middle_center);
  M5.Display.setFont(&fonts::FreeMonoBold18pt7b);
  M5.Display.drawString("Sleeping", W / 2, H / 2 - 18);
  M5.Display.setFont(&fonts::FreeMono12pt7b);
  M5.Display.drawString("Work saved.  Press the power button to wake.", W / 2, H / 2 + 26);
  M5.Display.setTextDatum(m5gfx::top_left);
  M5.Display.endWrite();
  delay(60);
  M5.Power.powerOff();           // ~9.6 uA; far lower than deep sleep on this board

  // We only get here if powerOff didn't take effect (e.g. running on USB power).
  // Recover gracefully to a clean menu rather than sitting on the sleep screen.
  g_lastActivity = millis();
  gotoMenu();
}

// =========================================================================
//  Reading positions & bookmarks (persisted to /.ptmarks.tsv on the SD card)
// =========================================================================
// Each file the Reader has opened gets a line "pos<TAB>bookmark<TAB>path":
// `pos` is the automatic where-you-left-off place (updated on every page
// turn, so even a hardware reset can't lose it), `bookmark` is the manually
// pinned page (-1 = none). Oldest entries fall off past MARKS_MAX.
// (struct ReadMark is defined near the top, with the other signature types.)
std::vector<ReadMark> g_readMarks;
bool g_marksLoaded = false;
const int MARKS_MAX = 48;

void marksLoad() {
  if (g_marksLoaded) return;
  g_marksLoaded = true;
  File f = SD.open("/.ptmarks.tsv", FILE_READ);
  if (!f) return;
  while (f.available() && (int)g_readMarks.size() < MARKS_MAX) {
    String line = f.readStringUntil('\n');
    line.trim();
    int t1 = line.indexOf('\t');
    int t2 = (t1 >= 0) ? line.indexOf('\t', t1 + 1) : -1;
    if (t1 <= 0 || t2 <= t1) continue;
    ReadMark m;
    m.pos  = line.substring(0, t1).toInt();
    m.bm   = line.substring(t1 + 1, t2).toInt();
    m.path = line.substring(t2 + 1);
    if (m.path.length()) g_readMarks.push_back(m);
  }
  f.close();
}

void marksSave() {
  File f = SD.open("/.ptmarks.tsv", FILE_WRITE, true);
  if (!f) return;
  for (auto &m : g_readMarks) {
    f.print(m.pos); f.print('\t'); f.print(m.bm); f.print('\t'); f.println(m.path);
  }
  f.close();
}

ReadMark *markFor(const String &path, bool create) {
  marksLoad();
  for (auto &m : g_readMarks) if (m.path == path) return &m;
  if (!create) return nullptr;
  if ((int)g_readMarks.size() >= MARKS_MAX) g_readMarks.erase(g_readMarks.begin());
  ReadMark m; m.path = path; m.pos = 0; m.bm = -1;
  g_readMarks.push_back(m);
  return &g_readMarks.back();
}

void markSetPos(const String &path, int pos) {
  ReadMark *m = markFor(path, true);
  if (m->pos == pos) return;               // no SD write when nothing changed
  m->pos = pos;
  marksSave();
}

// Remember the top of the current reader page as this file's reading place.
void readerSavePos() {
  if (filename.length() == 0 || g_lines.empty()) return;
  int r = g_readerTop;
  if (r >= (int)g_lines.size()) r = (int)g_lines.size() - 1;
  if (r < 0) r = 0;
  markSetPos(filename, g_lines[r].start);
}

// Open a file for reading at its saved place (or fallbackPos if never read).
void readerOpen(const String &path, int fallbackPos) {
  uint32_t sz;
  if (!docFits(path, sz)) {
    msgScreen("\"" + baseName(path) + "\" is too large to open here",
              "(" + String(sz / 1024) + " KB - not enough free memory).");
    return;
  }
  loadDoc(path);
  ReadMark *m = markFor(path, false);
  enterReaderAt((m && m->pos > 0) ? m->pos : fallbackPos);
}

// =========================================================================
//  Reader mode (read-only, paginated, touch-friendly)
// =========================================================================
// One Reader line with markdown styling: split into runs at '*' markers and
// switch the mono style per run. Markers stay visible (each occupies its
// cell), so wrap math and tap zones are untouched.
void drawStyledLine(int lineIdx, int y) {
  const Line &L = g_lines[lineIdx];
  int parStart;
  bool b, it, hd;
  mdStateAt(L.start, parStart, b, it, hd);
  int i = L.start, end = L.start + L.len, x = textX;
  while (i < end) {
    int runStart = i;
    while (i < end && doc[i] != '*') i++;
    if (i > runStart) {
      M5.Display.setFont(styleFont(b || hd, it));
      M5.Display.drawString(drawable(doc.substring(runStart, i)), x, y);
      x += (i - runStart) * charW;
    }
    if (i < end) {                                   // one or two stars
      bool dbl = (i + 1 < end && doc[i + 1] == '*');
      M5.Display.setFont(styleFont(b || hd, it));
      M5.Display.drawString(dbl ? "**" : "*", x, y);
      x += (dbl ? 2 : 1) * charW;
      if (dbl) {
        b = !b;
      } else {
        bool bullet = (i == parStart && i + 1 < (int)doc.length() &&
                       (doc[i + 1] == ' ' || doc[i + 1] == '\t'));
        if (!bullet) it = !it;
      }
      i += dbl ? 2 : 1;
    }
  }
}

int g_rdFastPages = 0;           // fast page turns since the last clean repaint

void drawReaderMode(bool allowFast) {
  // Page turns use the flash-free fast mode; every READER_QUALITY_EVERY-th
  // turn (and every entry/jump/rotate) gets a full-quality repaint to clear
  // the accumulated text ghosting.
  bool fast = allowFast && g_rdFastPages < READER_QUALITY_EVERY;
  g_rdFastPages = fast ? g_rdFastPages + 1 : 0;
  M5.Display.setEpdMode(fast ? m5gfx::epd_fast : m5gfx::epd_quality);
  M5.Display.startWrite();
  M5.Display.fillScreen(TFT_WHITE);

  int totalLines = (int)g_lines.size();
  int pages = (totalLines + g_rows - 1) / g_rows; if (pages < 1) pages = 1;
  int pg = g_readerTop / g_rows + 1;

  // header
  M5.Display.setFont(&fonts::FreeMono9pt7b);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  M5.Display.setTextDatum(m5gfx::top_left);
  M5.Display.drawString(baseName(filename), MARGIN_X, 5);
  M5.Display.setTextDatum(m5gfx::top_right);
  M5.Display.drawString(String("page ") + pg + "/" + pages, W - MARGIN_X, 5);
  M5.Display.setTextDatum(m5gfx::top_left);
  M5.Display.drawFastHLine(0, statusH - 1, W, TFT_BLACK);

  // body
  M5.Display.setFont(bodyFont());
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  for (int r = 0; r < g_rows; r++) {
    int idx = g_readerTop + r;
    if (idx >= totalLines) break;
    drawStyledLine(idx, textY + r * lineH);   // markdown-aware, latin-1-aware
  }
  M5.Display.endWrite();
}

// entries, jumps and rotations always get the clean full-quality repaint
void drawReader() { drawReaderMode(false); }

void enterReaderAt(int pos) {
  g_state = ST_READER;
  applyRotation(g_portrait);       // the reader may run portrait
  M5.Display.setFont(bodyFont());
  layout();
  g_readerTop = 0;
  if (pos > 0 && pos <= (int)doc.length()) {   // open on the page holding pos
    int row, col;
    caretRowCol(pos, row, col);
    g_readerTop = (row / g_rows) * g_rows;
  }
  drawReader();
}
void enterReader() { enterReaderAt(0); }

void readerNext() {
  if (g_readerTop + g_rows < (int)g_lines.size()) {
    g_readerTop += g_rows;
    readerSavePos();               // every page turn persists the place
    drawReaderMode(true);          // flash-free page turn
  }
}
void readerPrev() {
  if (g_readerTop > 0) {
    g_readerTop -= g_rows;
    if (g_readerTop < 0) g_readerTop = 0;
    readerSavePos();
    drawReaderMode(true);
  }
}

// jump to an absolute position (bookmark / page picker) and persist it
void readerJumpPos(int pos) {
  int row, col;
  caretRowCol(pos, row, col);
  g_readerTop = (row / g_rows) * g_rows;
  readerSavePos();
  g_state = ST_READER;
  drawReader();
}

// =========================================================================
//  Reading menu (tap the bottom edge, or 'b') + go-to-page picker
// =========================================================================
int g_rmSel = 0;

int pageOfPos(int pos) {
  int row, col;
  caretRowCol(pos, row, col);
  return row / g_rows + 1;
}

String rmLabel(int i) {
  ReadMark *m = markFor(filename, false);
  bool has = (m && m->bm >= 0);
  switch (i) {
    case 0: return String("Go to page...");
    case 1: return String("Set bookmark on this page");
    case 2: return has ? "Go to bookmark   (page " + String(pageOfPos(m->bm)) + ")"
                       : String("Go to bookmark   (none set)");
    case 3: return has ? String("Clear bookmark") : String("Clear bookmark   (none set)");
    case 4: return String("Back to reading");
  }
  return String();
}

void drawReaderMenu() {
  int bw = (W - 24 < 560) ? W - 24 : 560;    // fits portrait too
  drawModalList("Reading", bw, 380, rmLabel, 5, g_rmSel);
}

void enterReaderMenu() { g_state = ST_RMENU; g_rmSel = 0; drawReaderMenu(); }
void backToReader()    { g_state = ST_READER; drawReader(); }

void doReaderMenu(int i) {
  ReadMark *m;
  switch (i) {
    case 0: enterGoPage(); return;
    case 1:                                  // pin the current page
      m = markFor(filename, true);
      m->bm = g_lines.empty() ? 0
            : g_lines[(g_readerTop < (int)g_lines.size()) ? g_readerTop : 0].start;
      marksSave();
      backToReader();
      return;
    case 2:
      m = markFor(filename, false);
      if (m && m->bm >= 0) readerJumpPos(m->bm);
      else drawReaderMenu();                 // nothing to jump to
      return;
    case 3:
      m = markFor(filename, false);
      if (m && m->bm >= 0) { m->bm = -1; marksSave(); }
      backToReader();
      return;
    case 4: backToReader(); return;
  }
}

void handleReaderMenuKey(uint8_t ascii, uint8_t keycode) {
  if (keycode == KC_ESC) { backToReader(); return; }
  if (keycode == KC_UP)   { if (g_rmSel > 0) { g_rmSel--; modalListMoveSel(g_rmSel + 1, g_rmSel); } return; }
  if (keycode == KC_DOWN) { if (g_rmSel < 4) { g_rmSel++; modalListMoveSel(g_rmSel - 1, g_rmSel); } return; }
  if (ascii == 10 || ascii == 13 || keycode == KC_ENTER) doReaderMenu(g_rmSel);
}

void readerMenuTap(int x, int y) {
  int r = modalListHit(x, y);
  if (r == -1) { backToReader(); return; }
  if (r >= 0) doReaderMenu(r);
}

