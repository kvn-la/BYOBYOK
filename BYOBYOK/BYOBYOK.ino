  M5.Display.setFont(&fonts::FreeMonoBold18pt7b);
  M5.Display.drawString(String(g_goPage) + " / " + String(pages), g_gpNumX, g_gpNumY);

  M5.Display.setFont(&fonts::FreeMono12pt7b);
  static const char *lbl[4] = {"-10", "-1", "+1", "+10"};
  g_gpBtnW = (bw - 60 - 3 * 12) / 4;
  g_gpBtnY = by + 140;
  M5.Display.setTextDatum(m5gfx::middle_center);
  for (int i = 0; i < 4; i++) {
    g_gpBtnX[i] = bx + 30 + i * (g_gpBtnW + 12);
    M5.Display.drawRect(g_gpBtnX[i], g_gpBtnY, g_gpBtnW, GP_BTN_H, TFT_BLACK);
    M5.Display.drawString(lbl[i], g_gpBtnX[i] + g_gpBtnW / 2, g_gpBtnY + GP_BTN_H / 2);
  }
  g_gpGoW = (bw - 60 - 12) / 2;
  g_gpGoY = g_gpBtnY + GP_BTN_H + 20;
  static const char *lbl2[2] = {"Go", "Cancel"};
  for (int i = 0; i < 2; i++) {
    g_gpGoX[i] = bx + 30 + i * (g_gpGoW + 12);
    if (i == 0) {
      M5.Display.fillRect(g_gpGoX[i], g_gpGoY, g_gpGoW, GP_BTN_H, TFT_BLACK);
      M5.Display.setTextColor(TFT_WHITE, TFT_BLACK);
    } else {
      M5.Display.drawRect(g_gpGoX[i], g_gpGoY, g_gpGoW, GP_BTN_H, TFT_BLACK);
      M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
    }
    M5.Display.drawString(lbl2[i], g_gpGoX[i] + g_gpGoW / 2, g_gpGoY + GP_BTN_H / 2);
  }
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  M5.Display.setTextDatum(m5gfx::top_left);
  M5.Display.setFont(&fonts::FreeMono9pt7b);
  M5.Display.drawString("arrows = +/-1   PgUp/Dn = +/-10   type a number   Enter = go",
                        bx + 30, by + bh - 32);
  M5.Display.endWrite();
}

void enterGoPage() {
  g_state = ST_GOPAGE;
  int r = (g_readerTop < (int)g_lines.size()) ? g_readerTop : 0;
  g_goPage = r / g_rows + 1;
  g_gpTyped = false;
  drawGoPage();
}

void goPageDelta(int d) {
  int pages = readerPages();
  g_goPage += d;
  if (g_goPage < 1) g_goPage = 1;
  if (g_goPage > pages) g_goPage = pages;
  g_gpTyped = false;
  gpUpdateNumber();
}

void goPageJump() {
  int pages = readerPages();
  if (g_goPage < 1) g_goPage = 1;
  if (g_goPage > pages) g_goPage = pages;
  int row = (g_goPage - 1) * g_rows;
  if (row >= (int)g_lines.size()) row = (int)g_lines.size() - 1;
  readerJumpPos(g_lines.empty() ? 0 : g_lines[row].start);
}

void handleGoPageKey(uint8_t ascii, uint8_t keycode) {
  if (keycode == KC_ESC) { backToReader(); return; }
  if (keycode == KC_LEFT  || keycode == KC_UP)   { goPageDelta(-1);  return; }
  if (keycode == KC_RIGHT || keycode == KC_DOWN) { goPageDelta(+1);  return; }
  if (keycode == KC_PGUP) { goPageDelta(-10); return; }
  if (keycode == KC_PGDN) { goPageDelta(+10); return; }
  if (keycode == KC_HOME) { g_goPage = 1; g_gpTyped = false; gpUpdateNumber(); return; }
  if (keycode == KC_END)  { g_goPage = readerPages(); g_gpTyped = false; gpUpdateNumber(); return; }
  if (ascii == 10 || ascii == 13 || keycode == KC_ENTER) { goPageJump(); return; }
  if (ascii >= '0' && ascii <= '9') {
    int d = ascii - '0';
    g_goPage = g_gpTyped ? g_goPage * 10 + d : d;
    int pages = readerPages();
    if (g_goPage > pages) g_goPage = pages;
    if (g_goPage < 1) g_goPage = 1;
    g_gpTyped = true;
    gpUpdateNumber();
  }
}

void goPageTap(int x, int y) {
  if (y >= g_gpBtnY && y <= g_gpBtnY + GP_BTN_H) {
    static const int d[4] = {-10, -1, +1, +10};
    for (int i = 0; i < 4; i++)
      if (x >= g_gpBtnX[i] && x <= g_gpBtnX[i] + g_gpBtnW) { goPageDelta(d[i]); return; }
    return;
  }
  if (y >= g_gpGoY && y <= g_gpGoY + GP_BTN_H) {
    if (x >= g_gpGoX[0] && x <= g_gpGoX[0] + g_gpGoW) { goPageJump(); return; }
    if (x >= g_gpGoX[1] && x <= g_gpGoX[1] + g_gpGoW) { backToReader(); return; }
  }
}

void handleReaderKey(uint8_t ascii, uint8_t keycode) {
  if (keycode == KC_ESC) { gotoMenu(); return; }
  if ((ascii == 'e' || ascii == 'E') && g_kbConnected) {   // read -> edit
    applyRotation(false);                                  // editor is landscape
    enterEditor();
    return;
  }
  if (ascii == 'b' || ascii == 'B') { enterReaderMenu(); return; }  // bookmarks
  if (ascii == 'r' || ascii == 'R') {                      // rotate the reader
    int anchor = 0;
    if (!g_lines.empty()) {
      int row = g_readerTop;
      if (row >= (int)g_lines.size()) row = (int)g_lines.size() - 1;
      anchor = g_lines[row].start;
    }
    g_portrait = !g_portrait;
    saveLayout();
    enterReaderAt(anchor);        // re-wrap for the new shape, keep the place
    return;
  }
  if (keycode == KC_LEFT || keycode == KC_UP || keycode == KC_PGUP) { readerPrev(); return; }
  if (keycode == KC_RIGHT || keycode == KC_DOWN || keycode == KC_PGDN ||
      ascii == ' ' || ascii == 10 || ascii == 13) { readerNext(); return; }
}

void readerTap(int x, int y) {
  if (y < statusH) { gotoMenu(); return; }      // top band exits
  if (y > H - 44)  { enterReaderMenu(); return; }   // bottom band: reading menu
  if (x < W / 3) readerPrev(); else readerNext();
}

// Route a touch tap to the current screen. Every screen accepts touch, so a
// sleeping (or absent) keyboard can never leave you stranded anywhere.
void handleTap(int x, int y) {
  switch (g_state) {
    case ST_MENU:     menuTap(x, y);     break;
    case ST_READER:   readerTap(x, y);   break;
    case ST_BTPAIR:   btPairTap(x, y);   break;
    case ST_COUNT:    dismissCount();    break;
    case ST_GOAL:     goalTap(x, y);     break;
    case ST_STATS:    gotoMenu();        break;
    case ST_HELP:     gotoMenu();        break;
    case ST_EDITMENU: editMenuTap(x, y); break;
    case ST_CONFIRM:  confirmTap(x, y);  break;
    case ST_PROMPT:   promptCancel();    break;
    case ST_EXPORT:   stopExport();      break;
    case ST_SPELL:    spellTap(x, y);      break;
    case ST_SYNC:     stopSync();          break;
    case ST_RMENU:    readerMenuTap(x, y); break;
    case ST_GOPAGE:   goPageTap(x, y);     break;
    case ST_KEYTEST:
      if (ENABLE_BLE_KEYBOARD) { g_state = ST_BTPAIR; drawBtPair(); }
      else gotoMenu();
      break;
    case ST_EDIT: {                        // tap the page: place the cursor
      if (g_focus || y < textY) break;
      int row = topLine + (y - textY) / lineH;
      int col = (x - textX + charW / 2) / charW;
      cursorPos = posFromRowCol(row, col < 0 ? 0 : col);
      desiredCol = -1;
      afterChange(false);
      break;
    }
  }
}

// =========================================================================
//  Settings persistence (keyboard layout) + toggle
// =========================================================================
void loadLayout() {
  g_prefs.begin("paper", true);            // read-only
  // migrate the old boolean "dvorak" pref to the layout index transparently
  g_layout = g_prefs.getInt("layout", g_prefs.getBool("dvorak", false) ? 1 : 0);
  if (g_layout < 0 || g_layout >= LAYOUT_COUNT) g_layout = 0;
  g_fontSize = g_prefs.getInt("fontsz", 1);
  if (g_fontSize < 0 || g_fontSize > 2) g_fontSize = 1;
  g_portrait = g_prefs.getBool("portrait", false);
  g_prefs.end();
}
void saveLayout() {
  g_prefs.begin("paper", false);
  g_prefs.putInt("layout", g_layout);
  g_prefs.putInt("fontsz", g_fontSize);
  g_prefs.putBool("portrait", g_portrait);
  g_prefs.end();
}
void toggleLayout() { g_layout = (g_layout + 1) % LAYOUT_COUNT; saveLayout(); drawMenu(); }
void toggleFont() {
  g_fontSize = (g_fontSize + 1) % 3;
  saveLayout();
  setupMetrics();                          // new column/row grid for the editor
  drawMenu();
}
void toggleReaderRot() { g_portrait = !g_portrait; saveLayout(); drawMenu(); }

// =========================================================================
//  Setup / loop
// =========================================================================
// Ctrl+R anywhere: repaint the current screen at full quality (de-ghost).
void redrawScreen() {
  switch (g_state) {
    case ST_MENU:     g_menuFastCount = 0; drawMenu(); break;
    case ST_EDIT:     needDeghost = true; renderEditor(true); break;
    case ST_EDITMENU: drawEditMenu(); break;
    case ST_PROMPT:   drawPrompt(); break;
    case ST_CONFIRM:  drawConfirm(); break;
    case ST_EXPORT:   drawExport(); break;
    case ST_HELP:     drawHelp(); break;
    case ST_READER:   drawReader(); break;
    case ST_BTPAIR:   drawBtPair(); break;
    case ST_COUNT:    drawCountPopup(); break;
    case ST_GOAL:     drawGoal(); break;
    case ST_STATS:    drawStats(); break;
    case ST_SPELL:    drawSpell(); break;
    case ST_RMENU:    drawReaderMenu(); break;
    case ST_GOPAGE:   drawGoPage(); break;
    default: break;
  }
}

void setupMetrics() {
  M5.Display.setFont(&fonts::FreeMono9pt7b);
  statusH = M5.Display.fontHeight() + 10;
  M5.Display.setFont(bodyFont());               // editor/reader body size (S/M/L)
  charW = M5.Display.textWidth("M"); if (charW < 1) charW = 14;
  lineH = M5.Display.fontHeight() + 6;
  textX = MARGIN_X;
  textY = statusH + 4;
  g_cols = (W - 2 * MARGIN_X) / charW; if (g_cols < 8) g_cols = 8;
  g_rows = (H - textY - 6) / lineH;    if (g_rows < 1) g_rows = 1;
  prevVisible.assign(g_rows, String("\x01"));
}

void setup() {
  // Only bring up the subsystems we actually use. Keep RTC (clock), display and
  // power management; skip the gyro, buzzer and mic to save a little current.
  auto cfg = M5.config();
  cfg.internal_imu = false;   // built-in gyroscope: unused
  cfg.internal_spk = false;   // built-in buzzer: unused
  cfg.internal_mic = false;   // no mic on PaperS3 anyway
  cfg.internal_rtc = true;    // keep the clock running
  M5.begin(cfg);

  setCpuFrequencyMhz(CPU_MHZ);   // lower clock = less power (USB host still needs >= 80)
  M5.Display.setRotation(1);
  M5.Display.setEpdMode(m5gfx::epd_quality);
  W = M5.Display.width();
  H = M5.Display.height();
  setupMetrics();

  WiFi.mode(WIFI_OFF);     // keep the radio powered down until an export starts
  setupRtc();

  SPI.begin(SD_SPI_SCK_PIN, SD_SPI_MISO_PIN, SD_SPI_MOSI_PIN, SD_SPI_CS_PIN);
  bool sdok = SD.begin(SD_SPI_CS_PIN, SPI, 25000000);

  if (usbDriveFlagged()) {       // one-shot: boot as a USB drive instead
    usbDriveBoot(sdok);
    return;                      // no keyboard host, no menu this boot
  }

  M5.Display.startWrite();
  M5.Display.fillScreen(TFT_WHITE);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  M5.Display.setTextDatum(m5gfx::top_left);
  M5.Display.setFont(&fonts::FreeMonoBold18pt7b);
  M5.Display.drawString("BYOBYOK", MARGIN_X, 40);
  M5.Display.setFont(&fonts::FreeMono9pt7b);
  M5.Display.drawString(sdok ? "microSD: OK"
                             : "microSD: NOT FOUND - insert a FAT32 card and reset",
                        MARGIN_X, 100);
  M5.Display.drawString("Plug a USB keyboard into the USB-C port (OTG adapter).",
                        MARGIN_X, 124);
  M5.Display.endWrite();
  delay(1200);

  g_keepLatin1 = (USE_LATIN1_FONTS != 0);   // fold vs. keep accents on load
  loadLayout();           // restore QWERTY/Dvorak + font size from NVS
  setupMetrics();         // re-measure in case the saved font size isn't medium
  loadResume();           // last file + caret, for the [ Continue ] entry

  // 64-deep: a large auto-save can stall the loop for ~1s on novel-sized
  // files, and fast typing must not drop keys while that happens.
  g_keyQueue = xQueueCreate(64, sizeof(KeyEvt));
  usbHost.onKeyboard(onKbEvent);                 // register before begin()
  usbHost.begin();        // USB host takes over USB-C; serial monitor is gone now
  g_kbConnected = (usbHost.deviceCount() > 0);   // may flip true shortly after enumeration
  bleBoot();              // BLE keyboard: re-arm if one was paired (no-op if compiled out)
  buildEntries();
  g_sel = 0; menuTop = 0;
  g_lastActivity = millis();
  drawMenu();
}

void loop() {
  if (g_usbDriveMode) { usbDriveLoopTick(); return; }   // MSC boot: minimal loop
  M5.update();

  // Process any queued keypresses on this (drawing) task.
  KeyEvt e;
  while (g_keyQueue && xQueueReceive(g_keyQueue, &e, 0) == pdTRUE) {
    dispatchKey(e.ascii, e.keycode, e.modifiers, e.caps);
  }

  if (M5.BtnPWR.wasClicked()) goStandby();   // power-button short press = standby
  if (g_state == ST_EXPORT) server.handleClient();
  bleLoopTick();                             // BLE keyboard housekeeping (main task)

  // Writing goal / sprint: announce completion with the count popup.
  if (g_state == ST_EDIT && g_goalMode) {
    bool done = (g_goalMode == 1)
                  ? (millis() - g_goalStartMs >= (unsigned long)g_goalTarget * 60000UL)
                  : (g_docWords - g_goalStartWords >= g_goalTarget);
    if (done) {
      g_goalHit = true;
      enterCount();                          // draws the "Goal reached!" popup
      g_goalMode = 0;
    }
  }

  // Track keyboard presence, USB or BLE (drives edit-vs-read behavior and
  // menu labels). Only a *USB unplug* with no BLE fallback forces the
  // save-and-exit path: a BLE keyboard that drops out is usually just sleeping
  // to save its battery and reconnects on its next keypress, so mid-edit we
  // stay put (idle auto-standby still protects the work).
  static bool s_usbKb = false;
  bool usb = (usbHost.deviceCount() > 0);
  bool usbPulled = (s_usbKb && !usb);
  s_usbKb = usb;
  bool kb = usb || bleConnected();
  if (kb != g_kbConnected) {
    g_kbConnected = kb;
    if (!kb && usbPulled &&
        (g_state == ST_EDIT || g_state == ST_EDITMENU || g_state == ST_PROMPT)) {
      // keyboard pulled mid-edit: save and drop back to the touch menu (don't get stuck)
      saveWorkIfAny();
      gotoMenu();
    } else if (g_state == ST_MENU) {
      // Keyboard came or went: the entry list itself changes ([ New file ]
      // and [ New folder ] exist only when there are keys to type a name).
      g_sel = 0; menuTop = 0; g_btnSel = -1;
      buildEntries();
      drawMenu();
    }
  }

  // Touchscreen taps (menu navigation + reader page turns).
  if (M5.Touch.isEnabled()) {
    auto &t = M5.Touch.getDetail(0);
    if (t.wasClicked()) { g_lastActivity = millis(); handleTap(t.x, t.y); }
  }

  // De-ghost during a natural pause instead of mid-typing: once enough
  // partial updates have accumulated, a quiet stretch triggers one clean
  // full-quality repaint (the flash lands while you're thinking).
  if (g_state == ST_EDIT && partialCount >= DEGHOST_IDLE_MIN &&
      millis() - g_lastActivity > DEGHOST_IDLE_MS) {
    needDeghost = true;
    renderEditor(true);
  }

  // Auto-standby after a stretch of no typing (never while exporting).
  if (IDLE_SLEEP_MS > 0 && g_state != ST_EXPORT &&
      millis() - g_lastActivity >= IDLE_SLEEP_MS) {
    goStandby();
  }

  // Periodic tick: auto-save named files and refresh the battery indicator.
  if (millis() - g_lastTick >= AUTOSAVE_MS) {
    g_lastTick = millis();
    if (g_state == ST_EDIT) {
      int oldPct = g_batPct;
      readBattery();                                  // updates g_batPct/g_charging
      int curMin = g_lastMin;
      if (g_rtcOk) { auto dt = M5.Rtc.getDateTime(); curMin = dt.time.hours * 60 + dt.time.minutes; }
      bool saved = false;
      if (modified && filename.length() > 0) { saveFile(); saveResume(); saved = true; }
      if (saved || g_batPct != oldPct || curMin != g_lastMin) {
        g_lastMin = curMin;
        refreshStatusBar();
        prevModified = modified;                      // keep incremental render in sync
      }
    }
  }
  delay(1);
}
