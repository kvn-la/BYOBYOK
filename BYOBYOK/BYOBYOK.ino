// =========================================================================
//  Cloud sync ('c' in the menu, or the Cloud sync button)
//  Joins a real WiFi network and HTTP-PUTs every .txt in the current folder
//  to a WebDAV-style URL. Configured by /sync.cfg on the SD card:
//      ssid=MyNetwork
//      pass=secret
//      url=https://example.com/dav/writing/
//      user=me            (optional, HTTP basic auth)
//      pw=alsosecret      (optional)
//  HTTPS is accepted without certificate checking (see README).
//  (struct SyncCfg is defined near the top, with the other signature types.)
// =========================================================================
bool readSyncCfg(SyncCfg &c) {
  File f = SD.open("/sync.cfg", FILE_READ);
  if (!f) return false;
  while (f.available()) {
    String line = f.readStringUntil('\n');
    line.trim();
    int eq = line.indexOf('=');
    if (eq <= 0) continue;
    String k = line.substring(0, eq), v = line.substring(eq + 1);
    k.trim(); v.trim();
    if (k == "ssid") c.ssid = v;
    else if (k == "pass") c.pass = v;
    else if (k == "url")  c.url  = v;
    else if (k == "user") c.user = v;
    else if (k == "pw")   c.pw   = v;
  }
  f.close();
  return c.ssid.length() > 0 && c.url.length() > 0;
}

int g_syncY = 0;
void syncLine(const String &s) {               // append one progress line
  M5.Display.setEpdMode(m5gfx::epd_fast);
  M5.Display.startWrite();
  M5.Display.setFont(&fonts::FreeMono12pt7b);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  M5.Display.setTextDatum(m5gfx::top_left);
  M5.Display.drawString(s, MARGIN_X, g_syncY);
  M5.Display.endWrite();
  g_syncY += 32;
}

int syncPut(const SyncCfg &c, const String &name, File &f) {
  HTTPClient http;
  String full = c.url + urlEncode(name);
  int code = -1;
  if (c.url.startsWith("https:")) {
    WiFiClientSecure cl;
    cl.setInsecure();                          // no certificate pinning
    if (!http.begin(cl, full)) return -1;
    if (c.user.length()) http.setAuthorization(c.user.c_str(), c.pw.c_str());
    http.addHeader("Content-Type", "text/plain");
    code = http.sendRequest("PUT", &f, f.size());
    http.end();
  } else {
    WiFiClient cl;
    if (!http.begin(cl, full)) return -1;
    if (c.user.length()) http.setAuthorization(c.user.c_str(), c.pw.c_str());
    http.addHeader("Content-Type", "text/plain");
    code = http.sendRequest("PUT", &f, f.size());
    http.end();
  }
  return code;
}

void enterSync() {
  g_state = ST_SYNC;
  M5.Display.setEpdMode(m5gfx::epd_quality);
  M5.Display.startWrite();
  M5.Display.fillScreen(TFT_WHITE);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  M5.Display.setTextDatum(m5gfx::top_left);
  M5.Display.setFont(&fonts::FreeMonoBold18pt7b);
  M5.Display.drawString("Cloud sync", MARGIN_X, 24);
  M5.Display.endWrite();
  g_syncY = 90;

  SyncCfg c;
  if (!readSyncCfg(c)) {
    syncLine("No /sync.cfg found on the SD card.");
    syncLine("Create it with lines: ssid= pass= url=");
    syncLine("(plus optional user= and pw= for basic auth)");
    syncLine("ESC or tap to close.");
    return;
  }
  syncLine("Joining \"" + c.ssid + "\"...");
  WiFi.mode(WIFI_STA);
  WiFi.begin(c.ssid.c_str(), c.pass.c_str());
  unsigned long t0 = millis();
  while (WiFi.status() != WL_CONNECTED && millis() - t0 < 15000) delay(200);
  if (WiFi.status() != WL_CONNECTED) {
    WiFi.mode(WIFI_OFF);
    syncLine("Could not join the network.");
    syncLine("WiFi is off again. ESC or tap to close.");
    return;
  }
  if (!c.url.endsWith("/")) c.url += "/";

  int okN = 0, failN = 0;
  std::vector<String> files = listTxtFiles();
  for (auto &nm : files) {
    File f = SD.open(fullPath(nm).c_str(), FILE_READ);
    if (!f) { failN++; continue; }
    int code = syncPut(c, nm, f);
    f.close();
    bool ok = (code >= 200 && code < 300);
    syncLine(nm + (ok ? "  ok" : ("  FAILED (" + String(code) + ")")));
    ok ? okN++ : failN++;
  }
  WiFi.mode(WIFI_OFF);                         // radio back off, always
  syncLine("Done: " + String(okN) + " uploaded, " + String(failN) + " failed.");
  syncLine("WiFi is off again. ESC or tap to close.");
  g_lastActivity = millis();                   // a long sync isn't idle time
}

void stopSync() {
  WiFi.mode(WIFI_OFF);                         // idempotent safety
  gotoMenu();
}

void handleSyncKey(uint8_t ascii, uint8_t keycode) {
  (void)ascii; (void)keycode;                  // any key (or tap) closes
  stopSync();
}

