void handleConfirmKey(uint8_t ascii, uint8_t keycode) {
  if (keycode == KC_ESC) { gotoMenu(); return; }
  if (keycode == KC_LEFT || keycode == KC_RIGHT) {
    g_confirmSel = 1 - g_confirmSel;
    M5.Display.setEpdMode(m5gfx::epd_fast);    // just the two buttons, no flash
    M5.Display.startWrite();
    drawConfirmBtn(0);
    drawConfirmBtn(1);
    M5.Display.endWrite();
    return;
  }
  if (ascii == 'y' || ascii == 'Y') { SD.remove(fullPath(g_confirmName).c_str()); gotoMenu(); return; }
  if (ascii == 'n' || ascii == 'N') { gotoMenu(); return; }
  if (ascii == 10 || ascii == 13 || keycode == KC_ENTER) {
    if (g_confirmSel == 0) SD.remove(fullPath(g_confirmName).c_str());
    gotoMenu();
  }
}

// =========================================================================
//  WiFi export (SoftAP + tiny web server). Radio is only on while here.
// =========================================================================
String urlEncode(const String &s) {
  static const char *hex = "0123456789ABCDEF";
  String o;
  for (int i = 0; i < (int)s.length(); i++) {
    char c = s[i];
    if (isalnum((unsigned char)c) || c == '.' || c == '-' || c == '_') o += c;
    else { o += '%'; o += hex[(c >> 4) & 0xF]; o += hex[c & 0xF]; }
  }
  return o;
}

// All .txt files in the current folder (shared by export, sync).
std::vector<String> listTxtFiles() {
  std::vector<String> out;
  File root = SD.open(dirOpenPath().c_str());
  if (!root) return out;
  for (File f = root.openNextFile(); f; f = root.openNextFile()) {
    if (f.isDirectory()) continue;
    String nm = baseName(String(f.name()));
    if (nm.length() == 0 || nm[0] == '.') continue;   // .DS_Store, ._AppleDouble...
    String low = nm; low.toLowerCase();
    if (low.endsWith(".txt")) out.push_back(nm);
  }
  root.close();
  return out;
}

void handleRoot() {
  String html = F("<!doctype html><html><head><meta charset=utf-8>"
                  "<meta name=viewport content=\"width=device-width,initial-scale=1\">"
                  "<title>BYOBYOK</title>"
                  "<style>body{font-family:sans-serif;max-width:40em;margin:2em auto;padding:0 1em}"
                  "h1{font-size:1.3em}li{margin:.4em 0}a{text-decoration:none}</style>"
                  "</head><body><h1>BYOBYOK files</h1>");
  html += "<p style=color:#888>Folder: " + g_cwd + "</p><ul>";
  std::vector<String> files = listTxtFiles();
  for (auto &nm : files) {
    File f = SD.open(fullPath(nm).c_str(), FILE_READ);
    int sz = f ? (int)f.size() : 0;
    if (f) f.close();
    html += "<li><a href=\"/dl?f=" + urlEncode(nm) + "\">" + nm + "</a> &middot; "
            + String(sz) + " bytes</li>";
  }
  if (files.empty()) html += F("<li><i>no .txt files yet</i></li>");
  html += F("</ul>"
            "<h2 style=font-size:1.1em>Upload a .txt file</h2>"
            "<form method=post action=/upload enctype=multipart/form-data>"
            "<input type=file name=f accept=\".txt,text/plain\"> "
            "<button>Upload</button></form>"
            "<p style=color:#888>Tap a file above to download. Uploads are saved to "
            "the SD card (same-name files are overwritten). Opening this page also "
            "sets the device clock from your browser. Press ESC on the device to "
            "turn WiFi back off.</p>"
            "<script>{const d=new Date();fetch('/clock?y='+d.getFullYear()+'&mo='+"
            "(d.getMonth()+1)+'&d='+d.getDate()+'&h='+d.getHours()+'&mi='+"
            "d.getMinutes()+'&s='+d.getSeconds());}</script></body></html>");
  server.send(200, "text/html", html);
}

// The export page reports the browser's local time - a free, exact RTC sync
// with no NTP or internet needed.
void handleClock() {
  if (!g_rtcOk || !server.hasArg("y")) { server.send(400, "text/plain", "no"); return; }
  int y  = server.arg("y").toInt(),  mo = server.arg("mo").toInt();
  int d  = server.arg("d").toInt(),  h  = server.arg("h").toInt();
  int mi = server.arg("mi").toInt(), s  = server.arg("s").toInt();
  if (y < 2020 || y > 2099 || mo < 1 || mo > 12 || d < 1 || d > 31 ||
      h < 0 || h > 23 || mi < 0 || mi > 59 || s < 0 || s > 59) {
    server.send(400, "text/plain", "bad");
    return;
  }
  m5::rtc_datetime_t set;
  set.date.year = y; set.date.month = mo; set.date.date = d; set.date.weekDay = 0;
  set.time.hours = h; set.time.minutes = mi; set.time.seconds = s;
  M5.Rtc.setDateTime(set);
  server.send(200, "text/plain", "ok");
}

String sanitizeName(String nm) {
  int s = nm.lastIndexOf('/');  if (s >= 0) nm = nm.substring(s + 1);
  s = nm.lastIndexOf('\\');     if (s >= 0) nm = nm.substring(s + 1);
  return nm;
}

void handleUpload() {
  HTTPUpload &up = server.upload();
  if (up.status == UPLOAD_FILE_START) {
    String fn = sanitizeName(up.filename);
    if (fn.length() == 0) fn = "upload.txt";
    String low = fn; low.toLowerCase();
    if (!low.endsWith(".txt")) fn += ".txt";
    g_upFile = SD.open(fullPath(fn).c_str(), FILE_WRITE, true);   // into current folder
  } else if (up.status == UPLOAD_FILE_WRITE) {
    if (g_upFile) g_upFile.write(up.buf, up.currentSize);
  } else if (up.status == UPLOAD_FILE_END) {
    if (g_upFile) g_upFile.close();
  }
}

void handleUploadDone() {
  server.sendHeader("Location", "/");      // back to the listing (now updated)
  server.send(303, "text/plain", "");
}

void handleDownload() {
  if (!server.hasArg("f")) { server.send(400, "text/plain", "missing f"); return; }
  String name = server.arg("f");
  if (name.indexOf('/') >= 0 || name.indexOf('\\') >= 0) {   // no path traversal
    server.send(400, "text/plain", "bad name");
    return;
  }
  File f = SD.open(fullPath(name).c_str(), FILE_READ);
  if (!f) { server.send(404, "text/plain", "not found"); return; }
  server.sendHeader("Content-Disposition", "attachment; filename=\"" + name + "\"");
  server.streamFile(f, "text/plain");
  f.close();
}

void drawExport() {
  M5.Display.setEpdMode(m5gfx::epd_quality);
  M5.Display.startWrite();
  M5.Display.fillScreen(TFT_WHITE);
  M5.Display.setTextColor(TFT_BLACK, TFT_WHITE);
  M5.Display.setTextDatum(m5gfx::top_left);

  M5.Display.setFont(&fonts::FreeMonoBold18pt7b);
  M5.Display.drawString("WiFi Export", MARGIN_X, 24);

  String ip = WiFi.softAPIP().toString();
  M5.Display.setFont(&fonts::FreeMono12pt7b);
  int y = 90, dy = 40;
  M5.Display.drawString("1. Join this WiFi network:", MARGIN_X, y);          y += dy;
  M5.Display.drawString(String("     network:  ") + AP_SSID,  MARGIN_X, y);  y += dy;
  M5.Display.drawString(String("     password:  ") + AP_PASS, MARGIN_X, y);  y += dy + 8;
  M5.Display.drawString("2. Open this address in a browser:", MARGIN_X, y);  y += dy;
